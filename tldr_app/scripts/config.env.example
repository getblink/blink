# Optional local signing config for TLDR.app builds.
TLDR_TEAM_ID=
TLDR_BUNDLE_ID=com.henryz2004.tldr

# Optional: where the built app lives.
# TLDR_APP_PATH=/absolute/path/to/TLDR.app

# Optional: bake server proxy config into TLDR.app/DMG so users do not need
# ~/.tldr/.env. Use a revocable dogfood token from BLINK_API_TOKENS.
# TLDR_PROXY_URL=https://your-railway-service.up.railway.app
# TLDR_PROXY_TOKEN=
