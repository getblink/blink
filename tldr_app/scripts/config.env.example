# Optional local signing config for TLDR.app builds.
TLDR_TEAM_ID=
TLDR_BUNDLE_ID=com.henryz2004.tldr

# Optional: where the built app lives.
# TLDR_APP_PATH=/absolute/path/to/TLDR.app

# Optional: bake server proxy config into TLDR.app/DMG so users do not need
# ~/.tldr/.env. Use the bootstrap token for /v1/auth/mint; the app stores the
# minted per-device token at ~/.tldr/device_token.
# TLDR_PROXY_URL=https://your-railway-service.up.railway.app
# TLDR_PROXY_TOKEN=

# Sparkle / R2 release settings. Generate the key once with Sparkle's
# generate_keys tool; store the private key in Keychain and paste the public key
# into TLDR_SPARKLE_PUBLIC_ED_KEY for release builds.
# TLDR_SPARKLE_FEED_URL=https://downloads.example.com/tldr/appcast.xml
# TLDR_SPARKLE_PUBLIC_ED_KEY=
# TLDR_SPARKLE_SIGN_UPDATE=/path/to/sign_update
# TLDR_SPARKLE_KEYCHAIN_ACCOUNT=TLDR Sparkle EdDSA
# TLDR_R2_BUCKET=tldr-downloads
# TLDR_R2_PUBLIC_DOMAIN=downloads.example.com
# TLDR_R2_RELEASE_PREFIX=releases
# TLDR_R2_APPCAST_KEY=appcast.xml
# S3-compatible R2 token credentials (used by `aws s3 cp` in release.sh).
# Mint at: dashboard → R2 → Manage R2 API Tokens → Create. Copy the values
# from the "S3-compatible APIs" section (NOT the long API token).
# TLDR_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# TLDR_R2_ACCESS_KEY_ID=<32-hex-char access key id>
# TLDR_R2_SECRET_ACCESS_KEY=<64-hex-char secret>
