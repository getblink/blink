# Optional local signing config for Blink.app builds.
BLINK_TEAM_ID=
BLINK_BUNDLE_ID=com.henryz2004.blink

# Optional: where the built app lives.
# BLINK_APP_PATH=/absolute/path/to/Blink.app

# Optional: bake server proxy config into Blink.app/DMG so users do not need
# ~/.blink/.env. Use the bootstrap token for /v1/auth/mint; the app stores the
# minted per-device token at ~/.blink/device_token.
# BLINK_PROXY_URL=https://your-railway-service.up.railway.app
# BLINK_PROXY_TOKEN=

# Sparkle / R2 release settings. Generate the key once with Sparkle's
# generate_keys tool; store the private key in Keychain and paste the public key
# into BLINK_SPARKLE_PUBLIC_ED_KEY for release builds.
# BLINK_SPARKLE_FEED_URL=https://downloads.example.com/blink/appcast.xml
# BLINK_SPARKLE_PUBLIC_ED_KEY=
# BLINK_SPARKLE_SIGN_UPDATE=/path/to/sign_update
# BLINK_SPARKLE_KEYCHAIN_ACCOUNT=Blink Sparkle EdDSA
# BLINK_R2_BUCKET=blink-releases
# BLINK_R2_PUBLIC_DOMAIN=downloads.example.com
# BLINK_R2_RELEASE_PREFIX=releases
# BLINK_R2_APPCAST_KEY=appcast.xml
# S3-compatible R2 token credentials (used by `aws s3 cp` in release.sh).
# Mint at: dashboard → R2 → Manage R2 API Tokens → Create. Copy the values
# from the "S3-compatible APIs" section (NOT the long API token).
# BLINK_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BLINK_R2_ACCESS_KEY_ID=<32-hex-char access key id>
# BLINK_R2_SECRET_ACCESS_KEY=<64-hex-char secret>
