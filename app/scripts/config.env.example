# Copy to config.env (which is .gitignored) and fill in:
BLINK_TEAM_ID=XXXXXXXXXX                     # Apple Developer Team ID
BLINK_BUNDLE_ID=com.blink.tester.Blink       # must match project.yml / Info.plist
BLINK_SIGNING_ID="Developer ID Application: Your Name (XXXXXXXXXX)"
BLINK_NOTARY_PROFILE=blink-notary            # keychain profile, see `xcrun notarytool store-credentials --help`

# Optional: where the built app lives (defaults to app/build/Release/Blink.app)
# BLINK_APP_PATH=/absolute/path/to/Blink.app
