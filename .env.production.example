# Production proxy config embedded into Blink.app by app/scripts/release.sh.
#
# Copy this to .env.production at the repo root and fill in the real values.
# .env.production is gitignored (.env*). The release script aborts if either
# variable is missing or if BLINK_PROXY_URL contains "staging" — release
# builds MUST point at production.
#
# For local development, keep the staging values in .env (also gitignored)
# so install_local_app.sh and dogfood builds talk to staging without
# affecting what gets shipped to users.

BLINK_PROXY_URL=https://blink-production-7b5a.up.railway.app
BLINK_PROXY_TOKEN=
