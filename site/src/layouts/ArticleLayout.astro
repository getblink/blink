---
import Base from "./Base.astro";
import MetaFooter from "../components/MetaFooter.astro";
import BrandMark from "../components/BrandMark.astro";

interface RelatedLink {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  clusterLabel: string;
  related?: RelatedLink[];
}

const { title, description, publishedAt, clusterLabel, related = [] } =
  Astro.props;

const publishedISO = publishedAt.toISOString();
const publishedLabel = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base
  title={`${title} — Blink`}
  description={description}
  ogType="article"
  publishedAt={publishedISO}
>
  <main class="shell shell--scroll">
    <header class="row meta">
      <a class="cell" href="/">
        <BrandMark />
        <span>blink</span>
      </a>
      <a class="cell muted" href="/blog">blog</a>
      <div class="cell right muted">{clusterLabel.toLowerCase()}</div>
    </header>

    <section class="row article-row">
      <div class="cell article-cell">
        <article class="article">
          <h1>{title.toLowerCase()}</h1>
          <p class="article-date muted">
            <time datetime={publishedISO}>{publishedLabel}</time>
          </p>
          <slot />

          {
            related.length > 0 && (
              <nav class="related" aria-label="Related articles">
                <p class="related__label">related</p>
                <ul>
                  {related.map((link) => (
                    <li>
                      <a href={`/blog/${link.slug}`}>{link.title}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            )
          }
        </article>
      </div>
    </section>

    <MetaFooter />
  </main>

  <style>
    /* The blink cell is an <a> for back-nav; suppress the global link underline */
    header a.cell {
      border-bottom: 0;
    }

    .article-row {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .article-cell {
      padding: clamp(48px, 7vh, 88px) clamp(28px, 5vw, 64px)
        clamp(64px, 9vh, 112px);
      align-items: flex-start;
      justify-content: center;
    }

    .article {
      width: 100%;
      max-width: 640px;
    }

    .article :global(h1) {
      font-size: clamp(40px, 5.5vw, 64px);
      font-weight: 700;
      letter-spacing: -0.045em;
      line-height: 1;
      margin-bottom: 12px;
      color: var(--fg);
    }

    .article-date {
      font-size: 13px;
      margin-bottom: 36px;
    }

    .article :global(h2) {
      font-size: clamp(20px, 2vw, 24px);
      font-weight: 700;
      letter-spacing: -0.015em;
      line-height: 1.25;
      margin-top: 56px;
      margin-bottom: 16px;
      color: var(--fg);
    }

    .article :global(h3) {
      font-size: clamp(17px, 1.6vw, 19px);
      font-weight: 700;
      line-height: 1.3;
      margin-top: 36px;
      margin-bottom: 12px;
      color: var(--fg);
    }

    .article :global(p) {
      font-size: clamp(16px, 1.3vw, 18px);
      line-height: 1.65;
      color: #2a2a2a;
      margin-bottom: 18px;
      text-wrap: pretty;
    }

    .article :global(ul),
    .article :global(ol) {
      font-size: clamp(16px, 1.3vw, 18px);
      line-height: 1.65;
      color: #2a2a2a;
      margin: 0 0 18px 1.2em;
    }

    .article :global(li) {
      margin-bottom: 8px;
    }

    .article :global(blockquote) {
      margin: 0 0 18px;
      padding-left: 18px;
      border-left: 2px solid var(--line-soft);
      color: var(--fg-muted);
    }

    .article :global(code) {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 0.88em;
      background: rgba(29, 28, 33, 0.06);
      padding: 0.1em 0.35em;
      border-radius: var(--radius-sm);
    }

    .article :global(pre) {
      background: rgba(29, 28, 33, 0.06);
      padding: 16px 18px;
      border-radius: var(--radius-md);
      overflow-x: auto;
      margin-bottom: 18px;
    }

    .article :global(pre code) {
      background: none;
      padding: 0;
    }

    .article :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: var(--radius-md);
      margin: 8px 0 18px;
    }

    .article :global(a) {
      border-bottom: 1px solid var(--fg);
    }

    .article :global(a:hover) {
      background: var(--accent-soft);
      color: var(--fg);
    }

    .article-date :global(a),
    .article-date a {
      border-bottom: 0;
    }

    .related {
      margin-top: 64px;
      padding-top: 24px;
      border-top: 1px solid var(--line-soft);
    }

    .related__label {
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--fg-muted);
      margin-bottom: 14px;
    }

    .related ul {
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .related a {
      font-size: clamp(15px, 1.2vw, 17px);
      font-weight: 500;
      color: var(--fg);
    }

    @media (max-width: 880px) {
      .article-cell {
        padding: 40px 20px 64px;
      }

      .article :global(h2) {
        margin-top: 40px;
      }
    }
  </style>
</Base>
