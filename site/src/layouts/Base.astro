---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogType?: string;
  animateLandingOnce?: boolean;
}

const {
  title,
  description,
  ogType = "website",
  animateLandingOnce = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafaf7" />
    <link rel="icon" type="image/png" href="/blink-icon.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    {
      animateLandingOnce && (
        <script
          is:inline
          set:html={`try {
  if (sessionStorage.getItem('blink:shell-animated')) {
    document.documentElement.classList.add('no-shell-animate');
  } else {
    sessionStorage.setItem('blink:shell-animated', '1');
  }
} catch (e) {}`}
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
