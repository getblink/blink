---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  publishedAt?: string;
  // Optional: clean article title for the schema `headline` (without the
  // "— Blink" suffix the <title> tag carries). Falls back to `title`.
  headline?: string;
  // Optional: ISO timestamp for the article's last meaningful edit.
  modifiedAt?: string;
}

const {
  title,
  description,
  ogType = "website",
  ogImage = "/og-image.png",
  publishedAt,
  headline,
  modifiedAt,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// Shared entity definitions so author/publisher resolve to real, linked
// entities (helps both Google's knowledge graph and AI systems ground "who
// is Blink / Henry Zhang" rather than treating them as bare strings).
const blinkOrg = {
  "@type": "Organization",
  name: "Blink",
  url: Astro.site?.toString(),
  logo: {
    "@type": "ImageObject",
    url: new URL("/blink-icon.png", Astro.site).toString(),
  },
  sameAs: [
    "https://github.com/getblink/blink",
    "https://x.com/thehenryinsf",
  ],
};

const henryPerson = {
  "@type": "Person",
  name: "Henry Zhang",
  url: "https://x.com/thehenryinsf",
  sameAs: ["https://x.com/thehenryinsf"],
};

const websiteSchema = {
  "@type": "WebSite",
  name: "Blink",
  url: Astro.site?.toString(),
};

const softwareApplicationSchema = {
  "@type": "SoftwareApplication",
  name: "Blink",
  description,
  url: Astro.site?.toString(),
  operatingSystem: "macOS",
  applicationCategory: "ProductivityApplication",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    // Stable alias maintained by app/scripts/release.sh — points at the
    // most recent published DMG so this offer URL doesn't go stale.
    url: "https://dl.useblink.dev/latest/Blink.dmg",
  },
};

const articleSchema =
  ogType === "article"
    ? {
        "@type": "Article",
        headline: headline ?? title,
        description,
        url: canonicalURL.toString(),
        author: henryPerson,
        publisher: blinkOrg,
        ...(publishedAt ? { datePublished: publishedAt } : {}),
        ...(modifiedAt ? { dateModified: modifiedAt } : {}),
      }
    : null;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    websiteSchema,
    softwareApplicationSchema,
    ...(articleSchema ? [articleSchema] : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2f0e9" />
    <link rel="icon" type="image/svg+xml" href="/blink-logo.svg" />
    <link rel="icon" type="image/png" href="/blink-icon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Blink Blog"
      href={new URL("/rss.xml", Astro.site)}
    />
    <link rel="preconnect" href="https://dl.useblink.dev" crossorigin />
    <link rel="preconnect" href="https://us.i.posthog.com" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Blink" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Blink — reads your screen, writes the rest"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageURL} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
