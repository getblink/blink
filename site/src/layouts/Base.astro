---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  animateLandingOnce?: boolean;
  publishedAt?: string;
}

const {
  title,
  description,
  ogType = "website",
  ogImage = "/og-image.png",
  animateLandingOnce = false,
  publishedAt,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const websiteSchema = {
  "@type": "WebSite",
  name: "Blink",
  url: Astro.site?.toString(),
};

const softwareApplicationSchema = {
  "@type": "SoftwareApplication",
  name: "Blink",
  description,
  url: Astro.site?.toString(),
  operatingSystem: "macOS",
  applicationCategory: "ProductivityApplication",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    // Stable alias maintained by app/scripts/release.sh — points at the
    // most recent published DMG so this offer URL doesn't go stale.
    url: "https://dl.useblink.dev/latest/Blink.dmg",
  },
};

const articleSchema =
  ogType === "article"
    ? {
        "@type": "Article",
        headline: title,
        description,
        url: canonicalURL.toString(),
        author: { "@type": "Person", name: "Henry Zhang" },
        publisher: { "@type": "Organization", name: "Blink" },
        ...(publishedAt ? { datePublished: publishedAt } : {}),
      }
    : null;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    websiteSchema,
    softwareApplicationSchema,
    ...(articleSchema ? [articleSchema] : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafaf7" />
    <link rel="icon" type="image/png" href="/blink-icon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://dl.useblink.dev" crossorigin />
    <link rel="preconnect" href="https://us.i.posthog.com" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Blink" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Blink — reads your screen, writes the rest"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageURL} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    {
      animateLandingOnce && (
        <script
          is:inline
          set:html={`try {
  var html = document.documentElement;
  if (sessionStorage.getItem('blink:shell-animated')) {
    html.classList.add('no-shell-animate');
  } else {
    html.classList.add('pending-pointer');
    var startX = null;
    var startY = null;
    var trigger = function (event) {
      if (startX === null) {
        startX = event.clientX;
        startY = event.clientY;
        return;
      }
      var dx = event.clientX - startX;
      var dy = event.clientY - startY;
      if (dx * dx + dy * dy < 9) return;
      html.classList.remove('pending-pointer');
      try { sessionStorage.setItem('blink:shell-animated', '1'); } catch (e) {}
      window.removeEventListener('pointermove', trigger);
    };
    window.addEventListener('pointermove', trigger);
  }
} catch (e) {}`}
        />
      )
    }

    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
