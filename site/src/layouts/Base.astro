---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description: string;
  ogType?: string;
  animateLandingOnce?: boolean;
  publishedAt?: string;
}

const {
  title,
  description,
  ogType = "website",
  animateLandingOnce = false,
  publishedAt,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Blink",
  url: Astro.site?.toString(),
};

const articleSchema =
  ogType === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        url: canonicalURL.toString(),
        author: { "@type": "Person", name: "Henry Zhang" },
        publisher: { "@type": "Organization", name: "Blink" },
        ...(publishedAt ? { datePublished: publishedAt } : {}),
      }
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafaf7" />
    <link rel="icon" type="image/png" href="/blink-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Blink" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    {
      articleSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(articleSchema)}
        />
      )
    }

    {
      animateLandingOnce && (
        <script
          is:inline
          set:html={`try {
  var html = document.documentElement;
  if (sessionStorage.getItem('blink:shell-animated')) {
    html.classList.add('no-shell-animate');
  } else {
    html.classList.add('pending-pointer');
    var startX = null;
    var startY = null;
    var trigger = function (event) {
      if (startX === null) {
        startX = event.clientX;
        startY = event.clientY;
        return;
      }
      var dx = event.clientX - startX;
      var dy = event.clientY - startY;
      if (dx * dx + dy * dy < 9) return;
      html.classList.remove('pending-pointer');
      try { sessionStorage.setItem('blink:shell-animated', '1'); } catch (e) {}
      window.removeEventListener('pointermove', trigger);
    };
    window.addEventListener('pointermove', trigger);
  }
} catch (e) {}`}
        />
      )
    }

    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
