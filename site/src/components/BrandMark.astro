---
interface Props {
  size?: number;
}

const { size = 20 } = Astro.props;
// viewBox tightened to the artwork (+ a little shadow room) so the mark
// fills its box in the header instead of floating in padding.
const width = Math.round(size * 1.075);
---

<svg
  class="brand-mark"
  width={width}
  height={size}
  viewBox="57 78 544 506"
  fill="none"
  role="img"
  aria-label="Blink"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <filter
      id="bm-shadow"
      x="57"
      y="78"
      width="544"
      height="506"
      filterUnits="userSpaceOnUse"
      color-interpolation-filters="sRGB"
    >
      <feDropShadow
        dx="0"
        dy="5"
        stdDeviation="7"
        flood-color="#0f1724"
        flood-opacity="0.28"></feDropShadow>
      <feDropShadow
        dx="0"
        dy="1"
        stdDeviation="1.5"
        flood-color="#ffffff"
        flood-opacity="0.55"></feDropShadow>
    </filter>
    <filter
      id="bm-inner"
      x="122"
      y="139"
      width="428"
      height="393"
      filterUnits="userSpaceOnUse"
      color-interpolation-filters="sRGB"
    >
      <feDropShadow
        dx="0"
        dy="3"
        stdDeviation="3"
        flood-color="#0f1724"
        flood-opacity="0.32"></feDropShadow>
    </filter>
    <linearGradient
      id="bm-outer"
      x1="324"
      y1="102"
      x2="324"
      y2="553"
      gradientUnits="userSpaceOnUse"
    >
      <stop offset="0" stop-color="#343B4A"></stop>
      <stop offset="1" stop-color="#2B3240"></stop>
    </linearGradient>
    <linearGradient
      id="bm-face"
      x1="324"
      y1="156"
      x2="324"
      y2="509"
      gradientUnits="userSpaceOnUse"
    >
      <stop offset="0" stop-color="#FFF9F0"></stop>
      <stop offset="1" stop-color="#F9F1E7"></stop>
    </linearGradient>
  </defs>

  <g filter="url(#bm-shadow)">
    <path
      d="M87 238C87 161.8 148.8 100 225 100H423C499.2 100 561 161.8 561 238V416C561 492.2 499.2 554 423 554H225C148.8 554 87 492.2 87 416V238Z"
      fill="url(#bm-outer)"></path>
  </g>

  <g filter="url(#bm-inner)">
    <path
      d="M139 255C139 199.8 183.8 155 239 155H409C464.2 155 509 199.8 509 255V409C509 464.2 464.2 509 409 509H239C183.8 509 139 464.2 139 409V255Z"
      fill="url(#bm-face)"></path>
  </g>

  <circle class="blink-eye" cx="231" cy="321" r="30" fill="#172033"></circle>
  <circle class="blink-eye" cx="439" cy="321" r="30" fill="#172033"></circle>
  <path
    d="M278 389C292 431 377 432 392 389"
    stroke="#172033"
    stroke-width="31"
    stroke-linecap="round"></path>
</svg>

<style>
  .brand-mark {
    display: inline-block;
    flex-shrink: 0;
  }

  /* The eyes blink — once shortly after load (a greeting), and again on
     hover. transform-box keeps each eye scaling about its own centre. */
  .blink-eye {
    transform-box: fill-box;
    transform-origin: center;
    animation: brand-blink 380ms cubic-bezier(0.4, 0, 0.2, 1) 1100ms 1;
  }

  :global(.brand:hover) .blink-eye {
    animation: brand-blink 340ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes brand-blink {
    0%,
    100% {
      transform: scaleY(1);
    }
    45%,
    55% {
      transform: scaleY(0.1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blink-eye,
    :global(.brand:hover) .blink-eye {
      animation: none;
    }
  }
</style>
