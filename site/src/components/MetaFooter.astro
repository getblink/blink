---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__word">blink</span>
      <span class="muted">reads your screen, writes the rest.</span>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      <a href="/#how">how it works</a>
      <a href="/#faq">faq</a>
      <a href="/story">story</a>
      <a href="/blog">blog</a>
      <a href="/rss.xml">rss</a>
      <a href="https://github.com/getblink/blink" rel="noopener" target="_blank"
        >github</a
      >
      <a href="https://x.com/thehenryinsf" rel="noopener" target="_blank"
        >@thehenryinsf</a
      >
    </nav>

    <div class="footer__meta muted">
      <span>source-available · ELv2</span>
      <span>© {year}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line-faint);
    padding-block: clamp(32px, 5vh, 56px);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px 40px;
  }
  .footer__brand {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-size: 14px;
  }
  .footer__word {
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px 22px;
    font-size: 14px;
  }
  .footer__nav a {
    color: var(--fg-muted);
    border-bottom: 1px solid transparent;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .footer__nav a:hover {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .footer__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    font-size: 12.5px;
    text-align: right;
  }

  @media (max-width: 680px) {
    .footer__meta {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
