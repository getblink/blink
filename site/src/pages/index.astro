  <!-- Hero: reconstruct the painting from its own pixels as one wave fanning
       out from the tree. The crisp art sits under a cream cover; the wave
       dissolves that cover cell by cell, each cell doing cream → pointillist
       dot → crisp painting in one coupled motion (no global "image appears"). -->
  <script type="module">
    const hero = document.querySelector(".hero");
    const canvas = hero?.querySelector(".hero__build");
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const paint = () => hero?.classList.add("is-painted");

    if (!hero || !canvas || !canvas.getContext || reduce) {
      paint();
      canvas?.remove();
    } else {
      const ctx = canvas.getContext("2d");
      // One wave, fully coupled. The crisp painting sits beneath a solid cream
      // cover (this canvas) from the start. As the wave passes a cell it does
      // ONE motion: a pointillist dot pops in on the cream, then melts away as
      // that cell's cover dissolves to reveal the crisp art beneath. Cream →
      // dot → painting happens locally, per cell, on a single clock — so there
      // is no second "image appears all at once" event. Order is radial from
      // the tree, so it fans evenly rather than bursting from the middle.
      const END = 1.7; // slowest cell finishes ~1.45s; small tail
      let raf = 0,
        done = false,
        dots = [],
        w = 0,
        h = 0,
        t0 = 0,
        cream = [242, 240, 233],
        creamCss = "rgb(242,240,233)";

      const cleanup = () => {
        if (done) return;
        done = true;
        clearTimeout(failsafe);
        if (raf) cancelAnimationFrame(raf);
        paint();
        canvas.remove();
      };
      const failsafe = setTimeout(cleanup, 6000);
      const easeOut = (p) => 1 - Math.pow(1 - p, 3);
      // ease the master clock so the reveal eases in gently (a slow initial
      // fade-out) and settles out, rather than starting at full pace.
      const easeInOut = (p) =>
        p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2;
      const DURATION = 2.2; // real seconds; mapped onto the END wave timeline
      const clamp01 = (v) => (v < 0 ? 0 : v > 1 ? 1 : v);

      const render = (t) => {
        // Lay down the cream cover: it hides the crisp painting beneath until
        // the wave dissolves it, cell by cell.
        ctx.globalCompositeOperation = "source-over";
        ctx.globalAlpha = 1;
        ctx.fillStyle = creamCss;
        ctx.fillRect(0, 0, w, h);

        // Dissolve the cover where the wave has passed — a growing hole per
        // cell punches through to the crisp art. Holes overlap at full open so
        // no cream lattice is left behind (erasing overlap is invisible).
        ctx.globalCompositeOperation = "destination-out";
        for (const d of dots) {
          if (t < d.aS) continue;
          const e = easeOut(clamp01((t - d.aS) / d.aD));
          ctx.globalAlpha = e;
          ctx.beginPath();
          ctx.arc(d.x, d.y, d.hr * e, 0, 6.2832);
          ctx.fill();
        }

        // The pointillist dot itself: pops in on the cream, then melts to 0 as
        // its hole opens and the crisp art takes over. Same clock as the hole,
        // so cream → dot → painting is one coupled motion for each cell.
        ctx.globalCompositeOperation = "source-over";
        for (const d of dots) {
          if (t < d.aS) continue;
          const p = clamp01((t - d.aS) / d.aD);
          // pop to FULL strength fast, hold, then melt to 0 over the last ~45%
          // as the crisp art (revealed through the hole) takes the cell over
          const a = p < 0.55 ? clamp01(p * 4) : clamp01((1 - p) / 0.45);
          ctx.globalAlpha = a;
          const r = d.r0 + (d.fr - d.r0) * easeOut(p);
          ctx.beginPath();
          ctx.arc(d.x, d.y, r, 0, 6.2832);
          ctx.fillStyle = d.c;
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        ctx.globalCompositeOperation = "source-over";
      };

      const frame = (now) => {
        const p = clamp01((now - t0) / 1000 / DURATION);
        render(easeInOut(p) * END); // eased clock → slow, gentle onset
        if (p >= 1) cleanup();
        else raf = requestAnimationFrame(frame);
      };

      const start = () => {
        const rect = hero.getBoundingClientRect();
        w = rect.width;
        h = rect.height;
        if (w <= 0 || h <= 0) {
          cleanup();
          return;
        }
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        // cream tint = the page background, resolved to rgb. (Chrome reports
        // background-color back as oklch, so parse it through a canvas.)
        try {
          const pc = document.createElement("canvas").getContext("2d");
          pc.fillStyle = getComputedStyle(document.body).backgroundColor;
          pc.fillRect(0, 0, 1, 1);
          const px = pc.getImageData(0, 0, 1, 1).data;
          if (px[0] + px[1] + px[2] > 360) cream = [px[0], px[1], px[2]];
        } catch (e) {}
        creamCss = `rgb(${cream[0]},${cream[1]},${cream[2]})`;

        // sample the painting (cover-fit, top-anchored) at quarter res
        const sw = Math.max(1, Math.round(w * 0.25));
        const sh = Math.max(1, Math.round(h * 0.25));
        const off = document.createElement("canvas");
        off.width = sw;
        off.height = sh;
        const octx = off.getContext("2d");
        const ir = img.naturalWidth / img.naturalHeight;
        const fr = sw / sh;
        let dw, dh;
        if (ir > fr) {
          dh = sh;
          dw = sh * ir;
        } else {
          dw = sw;
          dh = sw / ir;
        }
        octx.drawImage(img, (sw - dw) / 2, 0, dw, dh);
        const data = octx.getImageData(0, 0, sw, sh).data;

        const gap = Math.max(11, Math.round(Math.sqrt((w * h) / 6000)));
        const xs = [];
        for (let x = gap / 2; x < w; x += gap) xs.push(x);
        const ys = [];
        for (let y = gap / 2; y < h; y += gap) ys.push(y);
        const cols = xs.length,
          rows = ys.length;
        const raw = [];
        // cool-weighted centroid of the upper canvas → the dense blue tree mass,
        // which is where the wave starts (no hand-traced geometry).
        let cwx = 0,
          cwy = 0,
          cwt = 0;
        for (let ry = 0; ry < rows; ry++) {
          const y = ys[ry];
          for (let cx = 0; cx < cols; cx++) {
            const x = xs[cx];
            const sx = Math.min(sw - 1, ((x / w) * sw) | 0);
            const sy = Math.min(sh - 1, ((y / h) * sh) | 0);
            const i = (sy * sw + sx) * 4;
            const cr = data[i],
              cg = data[i + 1],
              cb = data[i + 2];
            const lum = 0.299 * cr + 0.587 * cg + 0.114 * cb;
            // read the painting at this cell:
            const cool = Math.max(0, Math.min(1, (cb - cr) / 85)); // blue/teal
            const warm = Math.max(0, Math.min(1, (cr - cb) / 80)); // orange/peach
            const bright = Math.max(0, Math.min(1, (lum - 150) / 105)); // cream
            if (y < h * 0.62) {
              const cw = cool * cool;
              cwx += cw * x;
              cwy += cw * y;
              cwt += cw;
            }
            // bake the left-heavy cream wash (matches .hero::before) into the
            // colour, so the left reads light and the cross-fade is seamless
            const wf = 0.72 - 0.4 * (x / w);
            raw.push({
              x,
              y,
              r0: gap * 0.16, // a small dot when it lands
              fr: gap * 0.46, // the visible dot grows to here — transient and
              // fades out, so no fish-scale from overlapping opaque dots
              hr: gap * 0.78, // the cover-erase hole grows past the cell corner
              // (≈ half-diagonal) so the reveal leaves no cream lattice
              c: `rgb(${Math.round(cr + (cream[0] - cr) * wf)},${Math.round(
                cg + (cream[1] - cg) * wf,
              )},${Math.round(cb + (cream[2] - cb) * wf)})`,
              cool,
              warm,
              bright,
            });
          }
        }
        // wave origin = the cool-weighted centroid (the blue tree), floored to
        // the right half so it always starts from the tree side.
        const seedX = Math.max(w * 0.58, cwt > 0 ? cwx / cwt : w * 0.72);
        const seedY = cwt > 0 ? cwy / cwt : h * 0.42;
        // Colour-led sweep: starts at the tree and elongates toward the warm
        // sunset corner (which trails last). radial spreads it evenly (so no
        // corner is starved), proj gives the diagonal sweep, and the colour term
        // makes the cool blues lead while the warm corner resolves last.
        const diag = Math.hypot(w, h) || 1;
        const cornerX = w * 0.06,
          cornerY = h * 0.08;
        let vx = cornerX - seedX,
          vy = cornerY - seedY;
        const vlen = Math.hypot(vx, vy) || 1;
        vx /= vlen;
        vy /= vlen;
        let minO = Infinity,
          maxO = -Infinity;
        for (const d of raw) {
          const radial = Math.hypot(d.x - seedX, d.y - seedY) / diag;
          const proj = Math.max(
            0,
            ((d.x - seedX) * vx + (d.y - seedY) * vy) / diag,
          );
          const colour = d.warm * 0.5 + d.bright * 0.3 - d.cool * 0.2;
          d.o = radial * 0.42 + proj * 0.5 + colour * 0.3;
          if (d.o < minO) minO = d.o;
          if (d.o > maxO) maxO = d.o;
        }
        const spanO = maxO - minO || 1;
        const WAVE_SPAN = 0.95;
        for (const d of raw) {
          const t = (d.o - minO) / spanO; // 0 = tree/first, 1 = warm corner
          d.aS = Math.max(0, WAVE_SPAN * t + (Math.random() - 0.5) * 0.04);
          d.aD = 0.22 + Math.random() * 0.22;
        }
        dots = raw;
        // Cover the hero with cream BEFORE revealing the crisp art beneath, so
        // there's no flash: the canvas hides the painting until the wave
        // dissolves it. .is-painted brings .hero::before to full opacity now,
        // not at the end.
        ctx.fillStyle = creamCss;
        ctx.fillRect(0, 0, w, h);
        paint();
        t0 = performance.now();
        raf = requestAnimationFrame(frame);
      };

      const img = new Image();
      img.decoding = "async";
      img.onload = () => {
        try {
          start();
        } catch (e) {
          cleanup();
        }
      };
      img.onerror = cleanup;
      img.src = "/pointilism-3.webp";
    }
  </script>

  <!-- Reveal-on-scroll (has-js is already set pre-paint in the head) -->
  <script type="module">
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const items = Array.from(document.querySelectorAll(".reveal"));
    if (reduce || !("IntersectionObserver" in window)) {
      items.forEach((el) => el.classList.add("in"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target;
            // stagger siblings within a block for a bit of choreography
            const sibs = Array.from(
              el.parentElement?.querySelectorAll(":scope > .reveal") || [el],
            );
            const i = Math.max(0, sibs.indexOf(el));
            el.style.setProperty("--reveal-delay", `${Math.min(i, 6) * 90}ms`);
            el.classList.add("in");
            io.unobserve(el);
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
      );
      items.forEach((el) => io.observe(el));
      // Failsafe: never leave content hidden if the observer misbehaves.
      setTimeout(() => items.forEach((el) => el.classList.add("in")), 2200);
    }
  </script>

  <!-- Beta signup + referral share (logic preserved from the shipped form) -->
  <script type="module">
    const form = document.querySelector(".signup");
    const endpoint = form?.dataset.endpoint;
    const shareOrigin =
      (form?.dataset.shareOrigin || "").replace(/\/$/, "") || location.origin;
    const share = form?.querySelector(".share");
    const shareUrlInput = share?.querySelector(".share__url");
    const shareCopyButton = share?.querySelector(".share__copy");
    const shareCopyLabel = share?.querySelector(".share__copy-label");
    const shareEmailRow = share?.querySelector(".share__email");
    const shareEmailValue = share?.querySelector(".share__email-value");
    const statsBase = endpoint ? endpoint.replace(/\/+$/, "") : "";
    const SIGNUP_ID_RE = /^[0-9a-f]{32}$/;
    const STORAGE_KEY = "blink:signup_id";
    const STORAGE_EMAIL_KEY = "blink:signup_email";
    const readStoredSignupId = () => {
      try {
        const value = localStorage.getItem(STORAGE_KEY) || "";
        return SIGNUP_ID_RE.test(value) ? value : "";
      } catch {
        return "";
      }
    };
    const writeStoredSignupId = (signupId) => {
      try {
        localStorage.setItem(STORAGE_KEY, signupId);
      } catch {}
    };
    const readStoredEmail = () => {
      try {
        return localStorage.getItem(STORAGE_EMAIL_KEY) || "";
      } catch {
        return "";
      }
    };
    const writeStoredEmail = (email) => {
      try {
        localStorage.setItem(STORAGE_EMAIL_KEY, email);
      } catch {}
    };
    const incomingRef = (() => {
      try {
        const value = new URLSearchParams(location.search).get("ref") || "";
        return SIGNUP_ID_RE.test(value) ? value : "";
      } catch {
        return "";
      }
    })();
    if (incomingRef) {
      window.posthog?.capture("beta_signup_referred_visit", {
        ref: incomingRef,
        source: "useblink.dev",
      });
    }

    let currentSignupId = "";
    let goalMetCaptured = false;

    const showShareRow = (signupId, email) => {
      if (!share || !shareUrlInput) return;
      currentSignupId = signupId;
      const shareUrl = `${shareOrigin}/?ref=${signupId}`;
      shareUrlInput.value = shareUrl;
      const resolvedEmail = (email || readStoredEmail()).trim();
      if (resolvedEmail && shareEmailRow && shareEmailValue) {
        shareEmailValue.textContent = resolvedEmail;
        shareEmailRow.hidden = false;
      } else if (shareEmailRow) {
        shareEmailRow.hidden = true;
      }
      share.hidden = false;
      share.dataset.met = "false";
      share.dataset.copied = "false";
      goalMetCaptured = false;
      void refreshStats();
    };

    const refreshStats = async () => {
      if (!currentSignupId || !statsBase) return;
      try {
        const response = await fetch(`${statsBase}/${currentSignupId}/stats`, {
          method: "GET",
        });
        if (!response.ok) return;
        const body = await response.json();
        const referrals = Number(body?.referrals || 0);
        if (referrals >= 1) {
          share.dataset.met = "true";
          if (!goalMetCaptured) {
            goalMetCaptured = true;
            window.posthog?.capture("referral_goal_met", { referrals });
          }
        }
      } catch {}
    };

    shareCopyButton?.addEventListener("click", async () => {
      if (!shareUrlInput) return;
      const url = shareUrlInput.value;
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        shareUrlInput.select();
        try {
          document.execCommand("copy");
        } catch {}
      }
      share.dataset.copied = "true";
      if (shareCopyLabel) shareCopyLabel.textContent = "copied";
      window.posthog?.capture("referral_link_copied", {
        signup_id: currentSignupId,
      });
      setTimeout(() => {
        if (shareCopyLabel) shareCopyLabel.textContent = "copy link";
        share.dataset.copied = "false";
      }, 1800);
    });

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        void refreshStats();
      }
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!endpoint) return;
      const button = form.querySelector(".signup__submit");
      const data = new FormData(form);
      form.dataset.state = "submitting";
      button?.setAttribute("disabled", "true");
      if (share) {
        share.hidden = true;
        share.dataset.met = "false";
        share.dataset.copied = "false";
      }
      currentSignupId = "";
      goalMetCaptured = false;
      window.posthog?.capture("beta_signup_submitted", {
        source: "useblink.dev",
      });
      const submittedEmail = String(data.get("email") || "").trim();
      try {
        const body = {
          email: submittedEmail,
          hp: String(data.get("hp") || ""),
          source: "useblink.dev",
        };
        if (incomingRef) body.ref = incomingRef;
        const response = await fetch(endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(body),
        });
        if (response.status === 429) {
          form.dataset.state = "error-rate-limit";
          window.posthog?.capture("beta_signup_failed", {
            kind: "rate-limit",
            status: 429,
          });
          return;
        }
        if (response.status === 422) {
          form.dataset.state = "error-invalid";
          window.posthog?.capture("beta_signup_failed", {
            kind: "invalid",
            status: 422,
          });
          return;
        }
        if (response.ok) {
          let signupId;
          let alreadySignedUp = false;
          try {
            const responseBody = await response.json();
            signupId =
              typeof responseBody?.signup_id === "string"
                ? responseBody.signup_id
                : undefined;
            alreadySignedUp = responseBody?.already_signed_up === true;
          } catch {}
          if (alreadySignedUp) {
            form.dataset.state = "already";
            window.posthog?.capture("beta_signup_already_on_list");
          } else {
            form.dataset.state = "success";
            if (signupId) window.posthog?.alias(signupId);
            window.posthog?.capture("beta_signup_succeeded");
          }
          if (signupId && SIGNUP_ID_RE.test(signupId)) {
            writeStoredSignupId(signupId);
            if (submittedEmail) writeStoredEmail(submittedEmail);
            showShareRow(signupId, submittedEmail);
          }
        } else {
          form.dataset.state = "error-network";
          window.posthog?.capture("beta_signup_failed", {
            kind: "network",
            status: response.status,
          });
        }
      } catch {
        form.dataset.state = "error-network";
        window.posthog?.capture("beta_signup_failed", {
          kind: "network",
          status: 0,
        });
      } finally {
        button?.removeAttribute("disabled");
      }
    });

    // Returning visitor: restore the share row so a refresh doesn't wipe the
    // "you're on the list" + share UI.
    const storedSignupId = readStoredSignupId();
    if (storedSignupId && form) {
      form.dataset.state = "already";
      showShareRow(storedSignupId);
    }
  </script>
</Base>
