---
import Base from "../layouts/Base.astro";
import MetaFooter from "../components/MetaFooter.astro";
import BrandMark from "../components/BrandMark.astro";

const tagline = "reads your screen, writes the rest.";
const title = "Blink — reads your screen, writes the rest";
const betaSignupUrl =
  import.meta.env.PUBLIC_BETA_SIGNUP_URL ||
  "https://blink-production-7b5a.up.railway.app/v1/beta-signup";
const demoVideoUrls = (import.meta.env.PUBLIC_DEMO_VIDEO_URL || "")
  .split(",")
  .map((url: string) => url.trim())
  .filter((url: string) => url.length > 0);
---

<Base title={title} description={tagline} animateLandingOnce>
  <main class="shell shell--fixed shell--animate-in">
    <header class="row meta">
      <div class="cell">
        <BrandMark />
        <span>blink</span>
      </div>
      <div class="cell muted">landing / 01</div>
      <div class="cell muted">macOS · beta</div>
      <div class="cell right"><a href="/story">read the story →</a></div>
    </header>

    <section class="row hero" aria-labelledby="hero-title">
      <div class="cell wordmark-cell">
        <h1 class="wordmark" id="hero-title">
          <span class="wordmark__text">blink</span><span
            class="cursor"
            aria-hidden="true"></span>
        </h1>
        <p class="tagline">
          reads your screen,<br />
          writes the rest.
        </p>
        <form class="signup" data-state="idle" data-endpoint={betaSignupUrl}>
          <div class="signup__row">
            <label class="signup__label" for="email">join the beta</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              maxlength="320"
              required
            />
            <input
              class="hp"
              name="hp"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <button class="signup__submit" type="submit">join →</button>
          </div>
          <p class="status status--submitting">sending…</p>
          <p class="status status--success">you're on the list.</p>
          <p class="status status--already">you're already on the list.</p>
          <p class="status status--invalid">that doesn't look like an email.</p>
          <p class="status status--network">
            couldn't reach the server. try again in a moment.
          </p>
          <p class="status status--rate">too many tries. give it a minute.</p>
        </form>
      </div>
      <div
        class="cell demo-cell"
        data-video-urls={demoVideoUrls.join("|")}
      >
        {
          demoVideoUrls.length > 0 ? (
            <>
              <video
                class="demo__video is-active"
                data-slot="0"
                autoplay
                muted
                playsinline
                preload="auto"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={demoVideoUrls[0]}
                aria-label="Blink demo"
              />
              <video
                class="demo__video"
                data-slot="1"
                muted
                playsinline
                preload="auto"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={demoVideoUrls[1 % demoVideoUrls.length]}
              />
            </>
          ) : (
            <div class="demo__placeholder" aria-label="Demo video coming soon">
              <span>demo</span>
              <span class="muted">coming soon</span>
            </div>
          )
        }
      </div>
    </section>

    <MetaFooter />
  </main>

  <style>
    /* Hero row — landing-only */
    .hero {
      display: flex;
      align-items: stretch;
      min-height: 0;
    }

    .wordmark-cell {
      flex: 1;
      min-width: 0;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: clamp(28px, 5vh, 56px) clamp(28px, 4vw, 56px)
        clamp(20px, 3vh, 32px);
      gap: clamp(20px, 3vh, 32px);
    }

    .wordmark {
      font-size: clamp(4.5rem, 12vw, 11rem);
      font-weight: 700;
      line-height: 0.82;
      letter-spacing: -0.05em;
      display: inline-flex;
      align-items: baseline;
    }

    .wordmark__text {
      color: var(--fg);
    }

    .cursor {
      display: inline-block;
      width: 0.085em;
      height: 0.7em;
      background: var(--accent);
      margin-left: 0.05em;
      animation: blink 1.1s steps(2, jump-none) infinite;
    }

    @keyframes blink {
      0%,
      50% {
        opacity: 1;
      }
      50.01%,
      100% {
        opacity: 0;
      }
    }

    .tagline {
      font-size: clamp(1.05rem, 1.4vw, 1.4rem);
      font-weight: 500;
      line-height: 1.4;
      color: var(--fg);
      max-width: 38ch;
    }

    .demo-cell {
      position: relative;
      flex-shrink: 0;
      aspect-ratio: 3 / 4;
      height: 100%;
      max-width: 50%;
      padding: 0;
      gap: 0;
      background: var(--surface);
      overflow: hidden;
      display: block;
    }

    .demo__video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      opacity: 0;
      transition: opacity 240ms ease;
      pointer-events: none;
    }

    .demo__video.is-active {
      opacity: 1;
    }

    .demo__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 4px;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* Signup form — lives inside the wordmark cell, glued to the bottom */
    .signup {
      width: 100%;
      margin-top: auto;
      display: grid;
      gap: 8px;
    }

    .signup__row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 12px;
      align-items: center;
    }

    .signup__submit {
      height: 36px;
      padding: 0 14px;
      font: inherit;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--fg);
      border: 0;
      border-radius: 0;
      cursor: pointer;
      white-space: nowrap;
      transition: opacity 120ms ease;
    }

    .signup__submit:hover {
      opacity: 0.85;
    }

    .signup__submit:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .signup__submit:disabled {
      cursor: not-allowed;
      opacity: 0.5;
    }

    .signup__label {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--fg);
      white-space: nowrap;
    }

    input {
      height: 36px;
      font: inherit;
      font-size: 14px;
    }

    input[type="email"] {
      width: 100%;
      min-width: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      color: var(--fg);
      padding: 0;
      outline: none;
    }

    input[type="email"]::placeholder {
      color: var(--fg-muted);
    }

    .hp {
      position: absolute;
      left: -10000px;
      width: 1px;
      height: 1px;
      opacity: 0;
    }

    .status {
      font-size: 12px;
      line-height: 1.4;
      color: var(--fg-muted);
      min-height: 16px;
    }

    .status--submitting,
    .status--success,
    .status--already,
    .status--invalid,
    .status--network,
    .status--rate {
      display: none;
    }

    .signup[data-state="submitting"] .status--submitting,
    .signup[data-state="success"] .status--success,
    .signup[data-state="already"] .status--already,
    .signup[data-state="error-invalid"] .status--invalid,
    .signup[data-state="error-network"] .status--network,
    .signup[data-state="error-rate-limit"] .status--rate {
      display: block;
    }

    .status--success,
    .status--already {
      color: var(--fg);
      font-weight: 600;
    }

    @media (max-width: 880px) {
      .hero {
        flex-direction: column;
      }

      .wordmark-cell {
        border-right: 0;
        border-bottom: 1px solid var(--line);
        gap: 24px;
      }

      .wordmark {
        font-size: clamp(4rem, 22vw, 8rem);
      }

      .demo-cell {
        width: 100%;
        max-width: 100%;
        height: auto;
      }

      .signup__row {
        grid-template-columns: minmax(0, 1fr) auto;
      }

      .signup__label {
        grid-column: 1 / -1;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .cursor {
        animation: none;
        opacity: 1;
      }
    }
  </style>

  <script type="module">
    const form = document.querySelector(".signup");
    const endpoint = form?.dataset.endpoint;
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!endpoint) return;
      const button = form.querySelector("button");
      const data = new FormData(form);
      form.dataset.state = "submitting";
      button?.setAttribute("disabled", "true");
      window.posthog?.capture("beta_signup_submitted", {
        source: "useblink.dev",
      });
      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            email: String(data.get("email") || ""),
            hp: String(data.get("hp") || ""),
            source: "useblink.dev",
          }),
        });
        if (response.status === 429) {
          form.dataset.state = "error-rate-limit";
          window.posthog?.capture("beta_signup_failed", {
            kind: "rate-limit",
            status: 429,
          });
          return;
        }
        if (response.status === 422) {
          form.dataset.state = "error-invalid";
          window.posthog?.capture("beta_signup_failed", {
            kind: "invalid",
            status: 422,
          });
          return;
        }
        if (response.ok) {
          form.reset();
          let signupId;
          let alreadySignedUp = false;
          try {
            const body = await response.json();
            signupId = typeof body?.signup_id === "string" ? body.signup_id : undefined;
            alreadySignedUp = body?.already_signed_up === true;
          } catch {}
          if (alreadySignedUp) {
            form.dataset.state = "already";
            window.posthog?.capture("beta_signup_already_on_list");
          } else {
            form.dataset.state = "success";
            if (signupId) window.posthog?.alias(signupId);
            window.posthog?.capture("beta_signup_succeeded");
          }
        } else {
          form.dataset.state = "error-network";
          window.posthog?.capture("beta_signup_failed", {
            kind: "network",
            status: response.status,
          });
        }
      } catch {
        form.dataset.state = "error-network";
        window.posthog?.capture("beta_signup_failed", {
          kind: "network",
          status: 0,
        });
      } finally {
        button?.removeAttribute("disabled");
      }
    });

    const demoCell = document.querySelector(".demo-cell");
    const demoUrls = (demoCell?.dataset.videoUrls || "")
      .split("|")
      .filter(Boolean);
    const slots = demoCell?.querySelectorAll("video") || [];
    if (slots.length === 2 && demoUrls.length > 0) {
      let videoIndex = 0;
      let activeSlot = 0;
      const total = demoUrls.length;
      const advance = () => {
        videoIndex = (videoIndex + 1) % total;
        const nextSlot = 1 - activeSlot;
        const incoming = slots[nextSlot];
        const outgoing = slots[activeSlot];
        try {
          incoming.currentTime = 0;
        } catch {}
        incoming.classList.add("is-active");
        outgoing.classList.remove("is-active");
        incoming.play().catch(() => {});
        outgoing.pause();
        const followingIndex = (videoIndex + 1) % total;
        if (outgoing.src !== demoUrls[followingIndex]) {
          outgoing.src = demoUrls[followingIndex];
          outgoing.load();
        }
        activeSlot = nextSlot;
      };
      slots.forEach((video, i) => {
        video.addEventListener("ended", () => {
          if (i !== activeSlot) return;
          advance();
        });
      });
    }
  </script>
</Base>
