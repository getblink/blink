---
const tagline =
  "instant recall across every AI thread for multi‑agent power users";
const title = "Blink — instant recall across every AI thread";
const betaSignupUrl =
  import.meta.env.PUBLIC_BETA_SIGNUP_URL ||
  "https://blink-production-7b5a.up.railway.app/v1/beta-signup";
const demoVideoUrl = import.meta.env.PUBLIC_DEMO_VIDEO_URL || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={tagline} />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content="Blink" />
    <meta property="og:description" content={tagline} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <div class="ambient" aria-hidden="true"></div>
    <div class="grid" aria-hidden="true"></div>
    <div class="grid-spotlight" aria-hidden="true"></div>
    <div class="vignette" aria-hidden="true"></div>

    <main class="shell">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__copy">
          <h1 class="wordmark" id="hero-title">
            <span class="wordmark__text">blink</span><span
              class="cursor"
              aria-hidden="true"></span>
          </h1>
          <p class="tagline">
            instant recall across every AI thread<br class="tagline__break" />
            for multi‑agent power users
          </p>
        </div>

        <div class="demo">
          {demoVideoUrl ? (
            <video
              class="demo__video"
              controls
              muted
              loop
              playsinline
              preload="metadata"
              src={demoVideoUrl}
            ></video>
          ) : (
            <div class="demo__placeholder" aria-label="Demo video coming soon">
              demo coming soon
            </div>
          )}
        </div>

        <form class="signup" data-state="idle" data-endpoint={betaSignupUrl}>
          <label class="signup__label" for="email">Get the beta DMG</label>
          <div class="signup__row">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              maxlength="320"
              required
            />
            <input
              class="hp"
              name="hp"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <button type="submit">Join</button>
          </div>
          <p class="privacy">
            We'll only use your email to send the beta DMG. Stored on our
            server. No marketing.
          </p>
          <p class="status status--submitting">Sending…</p>
          <p class="status status--success">You're on the list.</p>
          <p class="status status--invalid">That doesn't look like an email.</p>
          <p class="status status--network">
            Couldn't reach the server. Try again in a moment.
          </p>
          <p class="status status--rate">Too many tries. Give it a minute.</p>
        </form>

        <p class="more">
          <a href="/story">learn more →</a>
        </p>
      </section>
    </main>

    <footer class="footer">
      <a href="https://github.com/henryz2004/blink">GitHub</a>
      <span>Source-available under ELv2</span>
      <a href="mailto:henry@useblink.dev">henry@useblink.dev</a>
    </footer>

    <style>
      :root {
        --bg: #09090b;
        --fg: #f5f5f7;
        --fg-muted: rgba(245, 245, 247, 0.82);
        --line: rgba(245, 245, 247, 0.16);
        --panel: rgba(245, 245, 247, 0.055);
        --accent: #8ee6d8;
        --mx: -9999px;
        --my: -9999px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        min-height: 100%;
        background: var(--bg);
        color: var(--fg);
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        position: relative;
        overflow-x: hidden;
      }

      .ambient {
        position: fixed;
        inset: 0;
        background:
          radial-gradient(
            ellipse 80% 55% at 50% 40%,
            rgba(255, 255, 255, 0.07),
            transparent 60%
          ),
          radial-gradient(
            ellipse 60% 40% at 50% 110%,
            rgba(120, 119, 198, 0.1),
            transparent 70%
          );
        pointer-events: none;
        z-index: 0;
      }

      .grid {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(
            to right,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          );
        background-size: 64px 64px;
        mask-image: radial-gradient(
          ellipse 70% 55% at 50% 50%,
          black 10%,
          transparent 75%
        );
        -webkit-mask-image: radial-gradient(
          ellipse 70% 55% at 50% 50%,
          black 10%,
          transparent 75%
        );
        pointer-events: none;
        z-index: 0;
      }

      .grid-spotlight {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(
            to right,
            rgba(255, 255, 255, 0.22) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.22) 1px,
            transparent 1px
          );
        background-size: 64px 64px;
        mask-image: radial-gradient(
          circle 280px at var(--mx) var(--my),
          #000 0%,
          rgba(0, 0, 0, 0.55) 45%,
          transparent 85%
        );
        -webkit-mask-image: radial-gradient(
          circle 280px at var(--mx) var(--my),
          #000 0%,
          rgba(0, 0, 0, 0.55) 45%,
          transparent 85%
        );
        pointer-events: none;
        z-index: 0;
      }

      .vignette {
        position: fixed;
        inset: 0;
        background: radial-gradient(
          ellipse 100% 100% at 50% 50%,
          transparent 55%,
          rgba(0, 0, 0, 0.55) 100%
        );
        pointer-events: none;
        z-index: 0;
      }

      .shell {
        position: relative;
        z-index: 1;
        width: 100%;
        min-height: calc(100svh - 70px);
        display: grid;
        align-items: center;
        padding: 48px 24px 28px;
      }

      .hero {
        width: min(1120px, 100%);
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 520px);
        gap: 40px 56px;
        align-items: center;
      }

      .hero__copy {
        text-align: left;
      }

      .wordmark {
        display: inline-flex;
        align-items: baseline;
        justify-content: flex-start;
        font-weight: 800;
        font-size: clamp(5.5rem, 11rem, 11rem);
        letter-spacing: 0;
        line-height: 0.95;
      }

      .wordmark__text {
        color: #ffffff;
      }

      .cursor {
        display: inline-block;
        width: 0.09em;
        height: 0.78em;
        background: #ffffff;
        margin-left: 0.06em;
        border-radius: 1px;
        animation: blink 1.1s steps(2, jump-none) infinite;
        box-shadow: 0 0 24px rgba(255, 255, 255, 0.4);
      }

      @keyframes blink {
        0%,
        50% {
          opacity: 1;
        }
        50.01%,
        100% {
          opacity: 0;
        }
      }

      .tagline {
        margin: 28px 0 0;
        max-width: 620px;
        font-size: clamp(1rem, 1.25rem, 1.25rem);
        font-weight: 500;
        line-height: 1.5;
        color: var(--fg-muted);
        letter-spacing: 0;
        text-wrap: balance;
      }

      .tagline__break {
        display: none;
      }

      .demo {
        width: 100%;
      }

      .demo__video,
      .demo__placeholder {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #111114;
        box-shadow: 0 26px 80px rgba(0, 0, 0, 0.35);
      }

      .demo__placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(245, 245, 247, 0.4);
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .signup {
        grid-column: 1 / -1;
        width: min(720px, 100%);
        display: grid;
        gap: 10px;
      }

      .signup__label {
        font-size: 0.88rem;
        font-weight: 700;
        color: rgba(245, 245, 247, 0.94);
      }

      .signup__row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 112px;
        gap: 10px;
      }

      input,
      button {
        height: 46px;
        border-radius: 8px;
        font: inherit;
      }

      input[type="email"] {
        width: 100%;
        min-width: 0;
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--fg);
        padding: 0 14px;
        outline: none;
      }

      input[type="email"]::placeholder {
        color: rgba(245, 245, 247, 0.42);
      }

      input[type="email"]:focus {
        border-color: rgba(142, 230, 216, 0.65);
        box-shadow: 0 0 0 3px rgba(142, 230, 216, 0.13);
      }

      button {
        border: 0;
        background: var(--fg);
        color: var(--bg);
        font-weight: 800;
        cursor: pointer;
      }

      button:disabled {
        cursor: wait;
        opacity: 0.7;
      }

      .hp {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        opacity: 0;
      }

      .privacy,
      .status {
        min-height: 20px;
        font-size: 0.84rem;
        line-height: 1.45;
      }

      .privacy {
        color: rgba(245, 245, 247, 0.62);
      }

      .status {
        display: none;
        color: var(--accent);
      }

      .signup[data-state="submitting"] .status--submitting,
      .signup[data-state="success"] .status--success,
      .signup[data-state="error-invalid"] .status--invalid,
      .signup[data-state="error-network"] .status--network,
      .signup[data-state="error-rate-limit"] .status--rate {
        display: block;
      }

      .more {
        grid-column: 1 / -1;
        margin: 0;
      }

      .more a {
        color: rgba(245, 245, 247, 0.65);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.01em;
        padding: 6px 10px;
        border-radius: 6px;
        transition: color 160ms ease, background 160ms ease;
      }

      .more a:hover {
        color: var(--fg);
        background: rgba(255, 255, 255, 0.04);
      }

      .more a:focus-visible {
        outline: 2px solid var(--fg);
        outline-offset: 2px;
      }

      .footer {
        position: relative;
        z-index: 1;
        width: min(1120px, calc(100% - 48px));
        min-height: 70px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        color: rgba(245, 245, 247, 0.5);
        font-size: 0.82rem;
      }

      .footer a {
        color: rgba(245, 245, 247, 0.68);
        text-decoration: none;
      }

      .footer a:hover {
        color: var(--fg);
      }

      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
          gap: 28px;
        }

        .hero__copy {
          text-align: center;
        }

        .wordmark {
          justify-content: center;
          font-size: clamp(5rem, 7.5rem, 7.5rem);
        }

        .tagline {
          margin-left: auto;
          margin-right: auto;
        }

        .signup {
          margin: 0 auto;
        }

        .more {
          text-align: center;
        }
      }

      @media (max-width: 600px) {
        .shell {
          padding: 34px 18px 24px;
        }

        .wordmark {
          font-size: clamp(4.4rem, 5.8rem, 5.8rem);
        }

        .tagline__break {
          display: inline;
        }

        .signup__row {
          grid-template-columns: 1fr;
        }

        .footer {
          width: calc(100% - 36px);
          flex-direction: column;
          align-items: flex-start;
          justify-content: center;
          padding: 20px 0 28px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .cursor {
          animation: none;
          opacity: 1;
        }
      }

      @media (hover: none) {
        .grid-spotlight {
          display: none;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        let x = 0;
        let y = 0;
        let pending = false;
        const flush = () => {
          root.style.setProperty("--mx", x + "px");
          root.style.setProperty("--my", y + "px");
          pending = false;
        };
        window.addEventListener(
          "pointermove",
          (e) => {
            x = e.clientX;
            y = e.clientY;
            if (!pending) {
              pending = true;
              requestAnimationFrame(flush);
            }
          },
          { passive: true }
        );
      })();
    </script>

    <script type="module">
      const form = document.querySelector(".signup");
      const endpoint = form?.dataset.endpoint;
      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!endpoint) return;
        const button = form.querySelector("button");
        const data = new FormData(form);
        form.dataset.state = "submitting";
        button?.setAttribute("disabled", "true");
        try {
          const response = await fetch(endpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              email: String(data.get("email") || ""),
              hp: String(data.get("hp") || ""),
              source: "useblink.dev",
            }),
          });
          if (response.status === 429) {
            form.dataset.state = "error-rate-limit";
            return;
          }
          if (response.status === 422) {
            form.dataset.state = "error-invalid";
            return;
          }
          form.dataset.state = response.ok ? "success" : "error-network";
          if (response.ok) form.reset();
        } catch {
          form.dataset.state = "error-network";
        } finally {
          button?.removeAttribute("disabled");
        }
      });
    </script>
  </body>
</html>
