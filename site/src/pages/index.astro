---
import Base from "../layouts/Base.astro";
import MetaFooter from "../components/MetaFooter.astro";
import BrandMark from "../components/BrandMark.astro";

const title = "Blink — reads your screen, writes the rest";
const description =
  "Blink is a local-first Mac assistant that reads your screen and drafts the reply for you: TL;DRs, follow-ups, and one-Cmd-V handoffs.";
const betaSignupUrl =
  import.meta.env.PUBLIC_BETA_SIGNUP_URL ||
  "https://blink-production-7b5a.up.railway.app/v1/beta-signup";
// Canonical share-link origin — sourced from astro.config.mjs `site` so
// the dev server doesn't bake localhost into copied/tweeted referral
// links. Falls back to location.origin client-side if unset.
const shareOrigin = (Astro.site?.toString() ?? "").replace(/\/$/, "");
const parseUrls = (raw: string) =>
  raw
    .split(",")
    .map((url: string) => url.trim())
    .filter((url: string) => url.length > 0);
const desktopDemoUrls = parseUrls(
  import.meta.env.PUBLIC_DEMO_VIDEO_URL_DESKTOP || "",
);
// PUBLIC_DEMO_VIDEO_URL_MOBILE is reserved for a future tighter mobile cut
// (still documented in .env.example). Until then both viewports render the
// desktop URLs — see the .demo-cell--mobile block below.
---

<Base title={title} description={description} animateLandingOnce>
  <main class="shell shell--fixed shell--animate-in">
    <header class="row meta">
      <div class="cell">
        <BrandMark />
        <span>blink</span>
      </div>
      <div class="cell muted">landing / 01</div>
      <div class="cell muted">macOS · beta</div>
      <div class="cell right"><a href="/story">read the story →</a></div>
    </header>

    <section class="row hero" aria-labelledby="hero-title">
      <div class="cell wordmark-cell">
        <h1 class="wordmark" id="hero-title">
          <span class="wordmark__text">blink</span><span
            class="cursor"
            aria-hidden="true"></span>
        </h1>
        <p class="tagline">
          reads your screen,<br />
          writes the rest.
        </p>
      </div>
      <div class="cell cta-cell">
        <form
          class="signup"
          data-state="idle"
          data-mode="collapsed"
          data-endpoint={betaSignupUrl}
          data-share-origin={shareOrigin}
        >
          <button
            class="signup__open"
            type="button"
            aria-expanded="false"
            aria-controls="signup-field"
          >
            <span>join the beta</span>
            <span class="signup__arrow" aria-hidden="true">→</span>
          </button>
          <div class="signup__field" id="signup-field">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              aria-label="email"
              maxlength="320"
              required
            />
            <input
              class="hp"
              name="hp"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <button class="signup__submit" type="submit">
              <span>join the beta</span>
              <span class="signup__arrow" aria-hidden="true">→</span>
            </button>
          </div>
          <p class="status status--submitting">sending…</p>
          <p class="status status--success">you're on the list.</p>
          <p class="status status--already">you're already on the list.</p>
          <p class="status status--invalid">that doesn't look like an email.</p>
          <p class="status status--network">
            couldn't reach the server. try again in a moment.
          </p>
          <p class="status status--rate">too many tries. give it a minute.</p>
          <div class="share" data-met="false" hidden>
            <p class="share__goal">
              <span class="share__check" aria-hidden="true">
                <svg
                  class="share__check-mark"
                  viewBox="0 0 16 16"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M3.5 8.5 L6.5 11.5 L12.5 4.5"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <span class="share__goal-text"
                >refer 1 friend to skip the line</span
              >
              <span class="share__goal-text--met"
                >referred 1 friend. you're in line for the next batch.</span
              >
            </p>
            <p class="share__email" hidden>
              signed up as <span class="share__email-value"></span>
            </p>
            <div class="share__row">
              <input
                class="share__url"
                type="text"
                readonly
                aria-label="your referral link"
              />
              <button class="share__copy" type="button">
                <span class="share__copy-label">copy</span>
              </button>
              <a
                class="share__tweet"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span>tweet</span>
                <span class="signup__arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </form>
        <a class="signup__secondary" href="/story">
          <span>read the story</span>
          <span class="signup__arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <div
        class="cell demo-cell demo-cell--desktop"
        data-video-urls={desktopDemoUrls.join("|")}
      >
        {
          desktopDemoUrls.length > 0 ? (
            <>
              <video
                class="demo__video is-active"
                data-slot="0"
                autoplay
                muted
                playsinline
                preload="auto"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={desktopDemoUrls[0]}
                aria-label="Blink demo"
              />
              <video
                class="demo__video"
                data-slot="1"
                muted
                playsinline
                preload="auto"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={desktopDemoUrls[1 % desktopDemoUrls.length]}
              />
            </>
          ) : (
            <div class="demo__placeholder" aria-label="Demo video coming soon">
              <span>demo</span>
              <span class="muted">coming soon</span>
            </div>
          )
        }
      </div>
      <div
        class="cell demo-cell demo-cell--mobile"
        data-video-urls={desktopDemoUrls.join("|")}
      >
        {
          desktopDemoUrls.length > 0 ? (
            <>
              <video
                class="demo__video is-active"
                data-slot="0"
                autoplay
                muted
                playsinline
                preload="none"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={desktopDemoUrls[0]}
                aria-label="Blink demo"
              />
              <video
                class="demo__video"
                data-slot="1"
                muted
                playsinline
                preload="none"
                disablepictureinpicture
                disableremoteplayback
                controlslist="nodownload nofullscreen noremoteplayback noplaybackrate"
                tabindex="-1"
                src={desktopDemoUrls[1 % desktopDemoUrls.length]}
              />
            </>
          ) : (
            <div class="demo__placeholder" aria-label="Demo video coming soon">
              <span>demo</span>
              <span class="muted">coming soon</span>
            </div>
          )
        }
      </div>
    </section>

    <MetaFooter />
  </main>

  <style>
    /* Hero row — landing-only. CSS Grid so the demo can sit in different
       positions per breakpoint without duplicating DOM nodes. */
    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-rows: 1fr auto;
      min-height: 0;
      overflow: hidden;
    }

    .wordmark-cell {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: clamp(28px, 5vh, 56px) clamp(28px, 4vw, 56px) 0;
      gap: clamp(20px, 3vh, 32px);
    }

    .cta-cell {
      grid-column: 1;
      grid-row: 2;
      min-width: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      padding: clamp(20px, 3vh, 32px) clamp(28px, 4vw, 56px)
        clamp(20px, 3vh, 32px);
    }

    .wordmark {
      font-size: clamp(4.5rem, 12vw, 11rem);
      font-weight: 700;
      line-height: 0.82;
      letter-spacing: -0.04em;
      display: inline-flex;
      align-items: baseline;
    }

    .wordmark__text {
      color: var(--fg);
    }

    .cursor {
      display: inline-block;
      width: 0.085em;
      height: 0.7em;
      background: var(--accent);
      margin-left: 0.05em;
      animation: blink 1.1s steps(2, jump-none) infinite;
    }

    @keyframes blink {
      0%,
      50% {
        opacity: 1;
      }
      50.01%,
      100% {
        opacity: 0;
      }
    }

    .tagline {
      font-size: clamp(1rem, 1.2vw, 1.25rem);
      font-weight: 500;
      line-height: 1.4;
      color: var(--fg);
      max-width: 38ch;
    }

    .demo-cell {
      position: relative;
      padding: 0;
      gap: 0;
      background: var(--surface);
      overflow: hidden;
      border-right: 0;
    }

    .demo-cell--desktop {
      grid-column: 2;
      grid-row: 1 / 3;
      aspect-ratio: 3 / 4;
      height: 100%;
      max-width: 50vw;
      display: block;
    }

    .demo-cell--mobile {
      display: none;
    }

    .demo__video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      opacity: 0;
      transition: opacity 240ms ease;
      pointer-events: none;
    }

    .demo-cell--mobile .demo__video {
      object-fit: cover;
    }

    .demo__video.is-active {
      opacity: 1;
    }

    .demo__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 4px;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
    }

    /* Signup form — lives inside cta-cell. */
    .signup {
      width: 100%;
      display: grid;
      gap: 10px;
    }

    .signup__open,
    .signup__submit {
      height: 48px;
      padding: 0 22px;
      font: inherit;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0;
      color: var(--bg);
      background: var(--fg);
      border: 0;
      border-radius: 0;
      cursor: pointer;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 14px;
      transition: opacity 120ms ease;
    }

    .signup__open {
      justify-self: start;
    }

    .signup__open:hover,
    .signup__submit:hover {
      opacity: 0.85;
    }

    .signup__open:focus-visible,
    .signup__submit:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .signup__submit:disabled {
      cursor: not-allowed;
      opacity: 0.5;
    }

    .signup__arrow {
      color: var(--accent);
      font-weight: 500;
      font-size: 1.05em;
      line-height: 1;
    }

    .signup__field {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
      animation: signup-field-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .signup[data-mode="collapsed"] .signup__field {
      display: none;
    }

    .signup[data-mode="expanded"] .signup__open {
      display: none;
    }

    @keyframes signup-field-in {
      from {
        opacity: 0;
        transform: translateY(3px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    input {
      height: 48px;
      font: inherit;
      font-size: 16px;
    }

    input[type="email"] {
      width: 100%;
      min-width: 0;
      border: 0;
      border-bottom: 1px solid var(--line);
      border-radius: 0;
      background: transparent;
      color: var(--fg);
      padding: 0 4px;
      outline: none;
      transition: border-color 160ms ease;
    }

    input[type="email"]:focus {
      border-bottom-color: var(--accent);
    }

    input[type="email"]::placeholder {
      color: var(--fg-muted);
    }

    .hp {
      position: absolute;
      left: -10000px;
      width: 1px;
      height: 1px;
      opacity: 0;
    }

    .status {
      font-size: 12px;
      line-height: 1.4;
      color: var(--fg-muted);
      min-height: 16px;
    }

    .status--submitting,
    .status--success,
    .status--already,
    .status--invalid,
    .status--network,
    .status--rate {
      display: none;
    }

    .signup[data-state="submitting"] .status--submitting,
    .signup[data-state="success"] .status--success,
    .signup[data-state="already"] .status--already,
    .signup[data-state="error-invalid"] .status--invalid,
    .signup[data-state="error-network"] .status--network,
    .signup[data-state="error-rate-limit"] .status--rate {
      display: block;
    }

    .status--success,
    .status--already {
      color: var(--fg);
      font-weight: 600;
    }

    .share {
      display: grid;
      gap: 10px;
      margin-top: 4px;
    }

    .share[hidden] {
      display: none;
    }

    .share__goal {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      font-weight: 500;
      color: var(--fg);
      line-height: 1.2;
    }

    .share__check {
      width: 14px;
      height: 14px;
      border: 1px solid var(--fg);
      box-sizing: border-box;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      align-self: center;
      transition: background 160ms ease, border-color 160ms ease;
    }

    .share__check-mark {
      width: 100%;
      height: 100%;
      color: var(--bg);
      opacity: 0;
      transition: opacity 160ms ease;
    }

    .share[data-met="true"] .share__check {
      background: var(--accent);
      border-color: var(--accent);
    }

    .share[data-met="true"] .share__check-mark {
      opacity: 1;
    }

    .share__email {
      font-size: 12px;
      line-height: 1.4;
      color: var(--fg-muted);
      margin: 0;
    }

    .share__email[hidden] {
      display: none;
    }

    .share__email-value {
      color: var(--fg);
      font-weight: 600;
    }

    .share__goal-text--met {
      display: none;
      color: var(--fg);
      font-weight: 500;
    }

    .share[data-met="true"] .share__goal-text {
      display: none;
    }

    .share[data-met="true"] .share__goal-text--met {
      display: inline;
    }

    .share__row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      gap: 8px;
      align-items: stretch;
    }

    .share__url {
      width: 100%;
      min-width: 0;
      height: 40px;
      padding: 0 10px;
      border: 1px solid var(--line-soft);
      border-radius: 0;
      background: var(--surface);
      color: var(--fg);
      font: inherit;
      font-size: 13px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      letter-spacing: 0;
    }

    .share__url:focus {
      outline: none;
      border-color: var(--accent);
    }

    .share__copy,
    .share__tweet {
      height: 40px;
      padding: 0 14px;
      font: inherit;
      font-size: 13px;
      font-weight: 600;
      color: var(--fg);
      background: transparent;
      border: 1px solid var(--line);
      border-radius: 0;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
      text-decoration: none;
      transition: background 120ms ease, color 120ms ease;
    }

    .share__copy:hover,
    .share__tweet:hover {
      background: var(--fg);
      color: var(--bg);
    }

    .share__copy:focus-visible,
    .share__tweet:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .share[data-copied="true"] .share__copy-label::after {
      content: " ✓";
      color: var(--accent);
    }

    .signup__secondary {
      display: none;
    }

    @media (max-width: 880px) {
      /* Single-column flow. wordmark+tagline pinned to top, form+secondary
         pinned to bottom, demo absorbs all remaining vertical space. */
      .hero {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto;
        min-height: 0;
      }

      .wordmark-cell {
        grid-column: 1;
        grid-row: 1;
        border-right: 0;
        border-bottom: 1px solid var(--line);
        padding: clamp(20px, 3vh, 32px) clamp(24px, 6vw, 40px)
          clamp(16px, 2vh, 24px);
        gap: clamp(12px, 2vh, 18px);
      }

      .wordmark {
        font-size: clamp(5rem, 26vw, 8.5rem);
      }

      .demo-cell--desktop {
        display: none;
      }

      .demo-cell--mobile {
        display: block;
        grid-column: 1;
        grid-row: 2;
        width: 100%;
        max-width: 100%;
        min-height: 0;
        border-bottom: 1px solid var(--line);
      }

      .cta-cell {
        grid-column: 1;
        grid-row: 3;
        border-right: 0;
        border-bottom: 0;
        padding: clamp(16px, 2.4vh, 24px) clamp(24px, 6vw, 40px)
          clamp(16px, 2.4vh, 24px);
      }

      /* On touch widths, skip the staging step — show the field by default
         and hide the open button. The desktop click-to-expand still applies
         above 880px. */
      .signup[data-mode="collapsed"] .signup__open {
        display: none;
      }

      .signup[data-mode="collapsed"] .signup__field {
        display: grid;
        animation: none;
      }

      .signup__field {
        grid-template-columns: minmax(0, 1fr);
        gap: 12px;
      }

      .signup__submit {
        width: 100%;
        justify-content: center;
      }

      .share__row {
        grid-template-columns: minmax(0, 1fr);
      }

      .share__copy,
      .share__tweet {
        width: 100%;
        justify-content: center;
      }

      .signup__secondary {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        align-self: center;
        height: 48px;
        padding: 0 22px;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0;
        color: var(--fg);
        border-bottom-color: transparent;
      }

      .signup__secondary:hover {
        color: var(--fg);
        opacity: 0.7;
        border-bottom-color: transparent;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .cursor {
        animation: none;
        opacity: 1;
      }

      .signup__field {
        animation: none;
      }

      input[type="email"] {
        transition: none;
      }
    }
  </style>

  <script type="module">
    const form = document.querySelector(".signup");
    const endpoint = form?.dataset.endpoint;
    // Canonical share-link origin baked in at build time from Astro.site.
    // Falls back to location.origin so dev/preview keeps working.
    const shareOrigin =
      (form?.dataset.shareOrigin || "").replace(/\/$/, "") ||
      location.origin;
    const openButton = form?.querySelector(".signup__open");
    const emailInput = form?.querySelector('input[type="email"]');
    const share = form?.querySelector(".share");
    const shareUrlInput = share?.querySelector(".share__url");
    const shareCopyButton = share?.querySelector(".share__copy");
    const shareCopyLabel = share?.querySelector(".share__copy-label");
    const shareTweetLink = share?.querySelector(".share__tweet");
    const shareEmailRow = share?.querySelector(".share__email");
    const shareEmailValue = share?.querySelector(".share__email-value");
    const statsBase = endpoint
      ? endpoint.replace(/\/+$/, "")
      : "";
    const SIGNUP_ID_RE = /^[0-9a-f]{32}$/;
    const STORAGE_KEY = "blink:signup_id";
    const STORAGE_EMAIL_KEY = "blink:signup_email";
    const readStoredSignupId = () => {
      try {
        const value = localStorage.getItem(STORAGE_KEY) || "";
        return SIGNUP_ID_RE.test(value) ? value : "";
      } catch {
        return "";
      }
    };
    const writeStoredSignupId = (signupId) => {
      try {
        localStorage.setItem(STORAGE_KEY, signupId);
      } catch {}
    };
    const readStoredEmail = () => {
      try {
        return localStorage.getItem(STORAGE_EMAIL_KEY) || "";
      } catch {
        return "";
      }
    };
    const writeStoredEmail = (email) => {
      try {
        localStorage.setItem(STORAGE_EMAIL_KEY, email);
      } catch {}
    };
    const incomingRef = (() => {
      try {
        const value = new URLSearchParams(location.search).get("ref") || "";
        return SIGNUP_ID_RE.test(value) ? value : "";
      } catch {
        return "";
      }
    })();
    if (incomingRef) {
      window.posthog?.capture("beta_signup_referred_visit", {
        ref: incomingRef,
        source: "useblink.dev",
      });
    }

    let currentSignupId = "";
    let goalMetCaptured = false;

    const showShareRow = (signupId, email) => {
      if (!share || !shareUrlInput || !shareTweetLink) return;
      currentSignupId = signupId;
      const shareUrl = `${shareOrigin}/?ref=${signupId}`;
      shareUrlInput.value = shareUrl;
      const tweetText =
        "just joined the blink beta. reads your screen, writes the rest.";
      shareTweetLink.href =
        "https://twitter.com/intent/tweet?text=" +
        encodeURIComponent(tweetText) +
        "&url=" +
        encodeURIComponent(shareUrl);
      const resolvedEmail = (email || readStoredEmail()).trim();
      if (resolvedEmail && shareEmailRow && shareEmailValue) {
        shareEmailValue.textContent = resolvedEmail;
        shareEmailRow.hidden = false;
      } else if (shareEmailRow) {
        shareEmailRow.hidden = true;
      }
      share.hidden = false;
      share.dataset.met = "false";
      share.dataset.copied = "false";
      goalMetCaptured = false;
      void refreshStats();
    };

    const refreshStats = async () => {
      if (!currentSignupId || !statsBase) return;
      try {
        const response = await fetch(
          `${statsBase}/${currentSignupId}/stats`,
          { method: "GET" },
        );
        if (!response.ok) return;
        const body = await response.json();
        const referrals = Number(body?.referrals || 0);
        if (referrals >= 1) {
          share.dataset.met = "true";
          if (!goalMetCaptured) {
            goalMetCaptured = true;
            window.posthog?.capture("referral_goal_met", {
              referrals,
            });
          }
        }
      } catch {}
    };

    shareCopyButton?.addEventListener("click", async () => {
      if (!shareUrlInput) return;
      const url = shareUrlInput.value;
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        shareUrlInput.select();
        try {
          document.execCommand("copy");
        } catch {}
      }
      share.dataset.copied = "true";
      if (shareCopyLabel) shareCopyLabel.textContent = "copied";
      window.posthog?.capture("referral_link_copied", {
        signup_id: currentSignupId,
      });
      setTimeout(() => {
        if (shareCopyLabel) shareCopyLabel.textContent = "copy";
        share.dataset.copied = "false";
      }, 1800);
    });

    shareTweetLink?.addEventListener("click", () => {
      window.posthog?.capture("referral_link_shared_twitter", {
        signup_id: currentSignupId,
      });
    });

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        void refreshStats();
      }
    });

    openButton?.addEventListener("click", () => {
      if (!form || form.dataset.mode === "expanded") return;
      form.dataset.mode = "expanded";
      openButton.setAttribute("aria-expanded", "true");
      window.posthog?.capture("beta_signup_expanded", {
        source: "useblink.dev",
      });
      requestAnimationFrame(() => emailInput?.focus());
    });
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!endpoint) return;
      const button = form.querySelector(".signup__submit");
      const data = new FormData(form);
      form.dataset.state = "submitting";
      button?.setAttribute("disabled", "true");
      if (share) {
        share.hidden = true;
        share.dataset.met = "false";
        share.dataset.copied = "false";
      }
      currentSignupId = "";
      goalMetCaptured = false;
      window.posthog?.capture("beta_signup_submitted", {
        source: "useblink.dev",
      });
      const submittedEmail = String(data.get("email") || "").trim();
      try {
        const body = {
          email: submittedEmail,
          hp: String(data.get("hp") || ""),
          source: "useblink.dev",
        };
        if (incomingRef) body.ref = incomingRef;
        const response = await fetch(endpoint, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(body),
        });
        if (response.status === 429) {
          form.dataset.state = "error-rate-limit";
          window.posthog?.capture("beta_signup_failed", {
            kind: "rate-limit",
            status: 429,
          });
          return;
        }
        if (response.status === 422) {
          form.dataset.state = "error-invalid";
          window.posthog?.capture("beta_signup_failed", {
            kind: "invalid",
            status: 422,
          });
          return;
        }
        if (response.ok) {
          let signupId;
          let alreadySignedUp = false;
          try {
            const responseBody = await response.json();
            signupId =
              typeof responseBody?.signup_id === "string"
                ? responseBody.signup_id
                : undefined;
            alreadySignedUp = responseBody?.already_signed_up === true;
          } catch {}
          if (alreadySignedUp) {
            form.dataset.state = "already";
            window.posthog?.capture("beta_signup_already_on_list");
          } else {
            form.dataset.state = "success";
            // Only alias the first time we learn this signup_id. Re-aliasing
            // on `already_signed_up` would clobber the identity graph.
            if (signupId) window.posthog?.alias(signupId);
            window.posthog?.capture("beta_signup_succeeded");
          }
          if (signupId && SIGNUP_ID_RE.test(signupId)) {
            writeStoredSignupId(signupId);
            if (submittedEmail) writeStoredEmail(submittedEmail);
            showShareRow(signupId, submittedEmail);
          }
        } else {
          form.dataset.state = "error-network";
          window.posthog?.capture("beta_signup_failed", {
            kind: "network",
            status: response.status,
          });
        }
      } catch {
        form.dataset.state = "error-network";
        window.posthog?.capture("beta_signup_failed", {
          kind: "network",
          status: 0,
        });
      } finally {
        button?.removeAttribute("disabled");
      }
    });

    // Returning visitor: restore the share row from localStorage so a
    // refresh doesn't wipe the "you're on the list" + share UI. We don't
    // know whether the original submit was a new signup or a duplicate,
    // so we surface the "already on the list" copy — accurate either way.
    const storedSignupId = readStoredSignupId();
    if (storedSignupId && form) {
      form.dataset.state = "already";
      showShareRow(storedSignupId);
    }

    document.querySelectorAll(".demo-cell").forEach((demoCell) => {
      const demoUrls = (demoCell.dataset.videoUrls || "")
        .split("|")
        .filter(Boolean);
      const slots = demoCell.querySelectorAll("video");
      if (slots.length !== 2 || demoUrls.length === 0) return;
      let videoIndex = 0;
      let activeSlot = 0;
      const total = demoUrls.length;
      const advance = () => {
        videoIndex = (videoIndex + 1) % total;
        const nextSlot = 1 - activeSlot;
        const incoming = slots[nextSlot];
        const outgoing = slots[activeSlot];
        try {
          incoming.currentTime = 0;
        } catch {}
        incoming.classList.add("is-active");
        outgoing.classList.remove("is-active");
        incoming.play().catch(() => {});
        outgoing.pause();
        const followingIndex = (videoIndex + 1) % total;
        if (outgoing.src !== demoUrls[followingIndex]) {
          outgoing.src = demoUrls[followingIndex];
          outgoing.load();
        }
        activeSlot = nextSlot;
      };
      slots.forEach((video, i) => {
        video.addEventListener("ended", () => {
          if (i !== activeSlot) return;
          advance();
        });
      });
    });
  </script>
</Base>
