---
import Base from "../layouts/Base.astro";
import TopBar from "../components/TopBar.astro";
import MetaFooter from "../components/MetaFooter.astro";

const title = "Blink — reads your screen, writes the rest";
const description =
  "Blink is a Mac assistant that reads your screen and writes the reply for you: summon it on any thread, it drafts in your voice and inserts the reply straight into the box. Invite-only macOS beta.";
const betaSignupUrl =
  import.meta.env.PUBLIC_BETA_SIGNUP_URL ||
  "https://api.useblink.dev/v1/beta-signup";
// Canonical share-link origin — sourced from astro.config.mjs `site` so the
// dev server doesn't bake localhost into copied/tweeted referral links.
const shareOrigin = (Astro.site?.toString() ?? "").replace(/\/$/, "");

const steps = [
  {
    n: "01",
    k: "see",
    t: "summon blink on any thread, doc, or dm. it reads what's on your screen. no pasting, no explaining.",
  },
  {
    n: "02",
    k: "draft",
    t: "it writes the reply the way you would: your phrasing, your tone, the context already there.",
  },
  {
    n: "03",
    k: "insert",
    t: "the draft lands straight in the box you were typing in. read it, tweak it, send.",
  },
];

const reasons = [
  {
    h: "it sees what you see.",
    t: "the context is already on your screen, so you stop re-explaining yourself to a chat box.",
  },
  {
    h: "it sounds like you, not like an ai.",
    t: "drafts in your voice instead of generic filler.",
  },
  {
    h: "it's always there, never in the way.",
    t: "blink follows you window to window, ready the moment you need it and quiet when you don't.",
  },
];

const privacy = [
  {
    h: "it only looks when you summon it.",
    t: "the rest of the time blink is idle. no background watching, no always-on recording.",
  },
  {
    h: "only what you point it at.",
    t: "when you ask for a draft, blink reads the conversation in front of you, just then. not your whole screen, not the rest of your day.",
  },
  {
    h: "you stay in control, and you can check.",
    t: "blink writes a draft and stops, you decide what to send. and because it's source-available, you can read exactly what it captures, or run the whole thing yourself.",
  },
];

const faqs = [
  {
    q: "who is blink for?",
    a: "founders living in claude code, their inbox, and x at the same time. creators and influencers buried in dms and replies. if you want to stop context switching, blink's for you.",
  },
  {
    q: "does blink send messages for me?",
    a: "no. it writes the draft into the box. you read it, edit it, and hit send yourself.",
  },
  {
    q: "what apps does it work in?",
    a: "anywhere you type: imessage, slack, gmail, discord, docs, and most native and web apps.",
  },
  {
    q: "can blink see the whole conversation, or just what's on screen?",
    a: "the whole conversation. it doesn't just grab the last few messages you can see, it reads the full thread, so the draft actually has the context.",
  },
  {
    q: "what happens to what blink reads?",
    a: "to write a draft, the text on your screen goes to an ai model. some of it is kept to help us improve blink, and you can turn that off anytime. if you'd rather keep everything on your own machine, blink is source-available to self-host.",
  },
  {
    q: "what will it cost?",
    a: "blink will be a paid product. the beta is hands-on and free while we get it right, and we'll talk pricing with you directly before it ever costs you anything.",
  },
  {
    q: "what do i need to run it?",
    a: "a mac, a couple of permissions (accessibility and screen recording), and a hotkey to summon blink. takes about a minute to set up.",
  },
  {
    q: "windows or iphone?",
    a: "not yet. blink is macOS only for now. join the waitlist and we'll let you know if that changes.",
  },
  {
    q: "why is it invite-only?",
    a: "because we onboard every person ourselves: set you up, learn how you work, and tune blink to fit. that only works a few people at a time, so we invite in small batches. leave your email and we'll reach out when there's room.",
  },
];
---

<Base title={title} description={description}>
  <!-- Set before first paint so reveal elements start hidden (no flash).
       JS-off visitors never get the class, so all content stays visible. -->
  <script is:inline>document.documentElement.classList.add("has-js");</script>

  <TopBar />

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <canvas class="hero__build" aria-hidden="true"></canvas>
      <div class="container hero__inner">
        <h1 class="wordmark reveal">
          <span class="wordmark__text">blink</span><span
            class="cursor"
            aria-hidden="true"></span>
        </h1>
        <p class="tagline reveal">reads your screen,<br />writes the rest.</p>
        <p class="subline reveal">stop holding 10 conversations in your head.</p>
        <div class="cta-row reveal">
          <a class="btn btn--primary" href="#join">
            <span>join the beta</span>
            <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
          <a class="btn btn--ghost hero__story" href="/story">
            <span>read the story</span>
          </a>
        </div>
        <p class="hero__meta reveal">invite-only · macOS beta</p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section how" id="how" aria-labelledby="how-lead">
      <div class="container how__inner">
        <div class="how__head">
          <p class="section__label reveal">how it works</p>
          <h2 class="section__lead reveal" id="how-lead">
            it reads, it drafts, it's in.
          </h2>
        </div>
        {/* Animated product demo lands here. Drop the HTML/CSS animation
           inside #how-demo; it cycles see → draft → insert, mirroring the
           three steps below. Add `is-active` to the matching .step (by its
           data-step) from the animation to sync the highlight. The screen is
           a 16:9 viewport — change .how__demo-screen's aspect-ratio to fit. */}
        <div
          class="how__demo reveal"
          id="how-demo"
          role="img"
          aria-label="Animated demo: Blink reads the screen, drafts a reply in your voice, and inserts it into the box."
        >
          <div class="how__demo-screen">
            <span class="how__demo-tag">product demo</span>
          </div>
        </div>
        <ol class="steps steps--row">
          {
            steps.map((s) => (
              <li class="step reveal" data-step={s.k}>
                <span class="step__n">{s.n}</span>
                <div>
                  <h3 class="step__k">{s.k}</h3>
                  <p class="step__t">{s.t}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- WHY -->
    <section class="section" id="why" aria-labelledby="why-lead">
      <div class="container section__inner">
        <p class="section__label reveal">why blink</p>
        <div class="section__content">
          <h2 class="sr-only">why blink</h2>
          <blockquote class="quote reveal" id="why-lead">
            <span class="quote__mark" aria-hidden="true">“</span>it feels like
            blink is reading my mind.
          </blockquote>
          <div class="reasons">
            {
              reasons.map((r) => (
                <div class="reason reveal">
                  <h3 class="reason__h">{r.h}</h3>
                  <p class="reason__t">{r.t}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- PRIVACY -->
    <section class="section" id="privacy" aria-labelledby="privacy-lead">
      <div class="container section__inner">
        <p class="section__label reveal">privacy</p>
        <div class="section__content">
          <h2 class="section__lead reveal" id="privacy-lead">
            reading your screen, without the creep.
          </h2>
          <p class="section__sub reveal">
            blink reads your screen so you never have to re-explain the
            conversation. here's what that does and doesn't mean.
          </p>
          <ul class="points">
            {
              privacy.map((p) => (
                <li class="point reveal">
                  <span class="point__tick" aria-hidden="true" />
                  <div>
                    <h3 class="point__h">{p.h}</h3>
                    <p class="point__t">{p.t}</p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq" aria-labelledby="faq-lead">
      <div class="container section__inner">
        <p class="section__label reveal">faq</p>
        <div class="section__content">
          <h2 class="section__lead reveal" id="faq-lead">
            questions people actually ask.
          </h2>
          <div class="faq">
            {
              faqs.map((f, i) => (
                <details class="qa reveal" name="faq">
                  <summary class="qa__q">
                    <span class="qa__n">{String(i + 1).padStart(2, "0")}</span>
                    <span class="qa__text">{f.q}</span>
                    <span class="qa__mark" aria-hidden="true" />
                  </summary>
                  <p class="qa__a">{f.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- JOIN -->
    <section class="section join" id="join" aria-labelledby="join-lead">
      <div class="container">
        <div class="join__inner">
        <h2 class="join__title reveal" id="join-lead">
          blink keeps the threads.<br />you keep your head.
        </h2>

        <form
          class="signup reveal"
          data-state="idle"
          data-endpoint={betaSignupUrl}
          data-share-origin={shareOrigin}
        >
          <div class="signup__field" id="signup-field">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@email.com"
              aria-label="email"
              maxlength="320"
              required
            />
            <input
              class="hp"
              name="hp"
              type="text"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <button class="btn btn--primary signup__submit" type="submit">
              <span>join the beta</span>
              <span class="btn__arrow" aria-hidden="true">→</span>
            </button>
          </div>
          <p class="status status--submitting">sending…</p>
          <p class="status status--success">you're on the list.</p>
          <p class="status status--already">you're already on the list.</p>
          <p class="status status--invalid">that doesn't look like an email.</p>
          <p class="status status--network">
            couldn't reach the server. try again in a moment.
          </p>
          <p class="status status--rate">too many tries. give it a minute.</p>
          <div class="share" data-met="false" hidden>
            <p class="share__goal">
              <span class="share__goal-text"
                >you're on the list. share to skip the line.</span
              >
              <span class="share__goal-text--met"
                >shared with 1 friend. you're in line for the next batch.</span
              >
            </p>
            <div class="share__row">
              <input
                class="share__url"
                type="text"
                readonly
                aria-label="your referral link"
              />
              <button class="share__copy" type="button">
                <span class="share__copy-label">copy link</span>
              </button>
            </div>
            <p class="share__email" hidden>
              signed up as <span class="share__email-value"></span>
            </p>
          </div>
        </form>

        <p class="join__note reveal">
          invite-only macOS beta. we onboard everyone personally, so we let
          people in a few at a time.
        </p>
        <p class="join__note reveal">
          on an iphone or a windows pc? blink is mac-only for now. drop your
          email and we'll ping you when you can use it.
        </p>
        </div>
      </div>
    </section>
  </main>

  <MetaFooter />

  <style>
    /* ============================================================= *
     * HERO — text only, big and confident
     * ============================================================= */
    .hero {
      position: relative;
      min-height: calc(100svh - var(--topbar-h));
      display: flex;
      align-items: center;
      padding-block: clamp(56px, 9vh, 120px);
      overflow: hidden;
    }
    /* The painting lives only here. A left-heavy cream wash keeps the
       (left-aligned) text legible while the art stays vivid toward the
       right; a soft fade at the bottom hands off to the cream page below. */
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      background-image: linear-gradient(
          100deg,
          color-mix(in oklch, var(--paper) 75%, transparent) 0%,
          color-mix(in oklch, var(--paper) 50%, transparent) 50%,
          color-mix(in oklch, var(--paper) 34%, transparent) 100%
        ),
        url("/pointilism-3.webp");
      background-size: cover, cover;
      background-position: center top, center top;
      -webkit-mask-image: linear-gradient(
        to bottom,
        #000 72%,
        transparent 100%
      );
      mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
    }
    /* With JS, the crisp painting starts hidden; the canvas covers it in cream
       and dissolves that cover cell by cell to reveal it. The painting is
       brought to full opacity instantly (.is-painted, set at animation start)
       beneath the cover — the canvas, not a CSS fade, drives the reveal.
       No-JS / reduced-motion keep the painting visible from the start. */
    :global(html.has-js) .hero::before {
      opacity: 0;
    }
    :global(html.has-js) .hero.is-painted::before {
      opacity: 1;
    }
    /* canvas that paints the dots in, on top of the (hidden) painting,
       below the text */
    .hero__build {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      -webkit-mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
      mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
    }
    @media (prefers-reduced-motion: reduce) {
      :global(html.has-js) .hero::before {
        opacity: 1;
        transition: none;
      }
    }
    .hero__inner {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(20px, 2.6vh, 30px);
    }
    .wordmark {
      font-size: clamp(5rem, 16vw, 15rem);
      font-weight: 760;
      line-height: 0.82;
      letter-spacing: -0.045em;
      color: var(--fg);
      display: inline-flex;
      align-items: baseline;
    }
    .cursor {
      display: inline-block;
      width: 0.07em;
      height: 0.66em;
      background: var(--sky);
      margin-left: 0.06em;
      border-radius: 1px;
      animation: caret-blink 1.1s steps(2, jump-none) infinite;
    }
    @keyframes caret-blink {
      0%,
      50% {
        opacity: 1;
      }
      50.01%,
      100% {
        opacity: 0;
      }
    }
    .tagline {
      font-size: clamp(1.5rem, 2.4vw, 2.2rem);
      font-weight: 560;
      line-height: 1.1;
      letter-spacing: -0.025em;
      color: var(--fg);
    }
    .subline {
      font-size: clamp(1.05rem, 1.3vw, 1.2rem);
      line-height: 1.5;
      color: var(--fg-2);
      max-width: 38ch;
    }
    .cta-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 22px;
      margin-top: 8px;
    }
    /* darker than the global ghost button so it stays legible on the
       painting */
    .hero__story.btn--ghost {
      gap: 8px;
      color: var(--fg-2);
      font-weight: 600;
    }
    .hero__story.btn--ghost:hover {
      color: var(--fg);
    }
    .hero__meta {
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.02em;
      color: var(--fg-2);
      margin-top: 2px;
    }

    /* ============================================================= *
     * SECTION — minimal left label rail + content that leads
     * ============================================================= */
    .section {
      padding-block: clamp(72px, 13vh, 168px);
    }
    .section__inner {
      display: grid;
      grid-template-columns: minmax(0, 190px) minmax(0, 1fr);
      gap: clamp(32px, 7vw, 112px);
      align-items: start;
    }
    /* A sticky section anchor — the section name as a real, present header
       that tracks beside the content as you read it. */
    .section__label {
      position: sticky;
      top: calc(var(--topbar-h) + 38px);
      font-size: clamp(1.2rem, 1.5vw, 1.5rem);
      font-weight: 680;
      letter-spacing: -0.02em;
      line-height: 1.12;
      color: var(--fg);
      max-width: 8ch;
    }
    .section__content {
      max-width: 760px;
    }
    .section__content > * + * {
      margin-top: clamp(30px, 4.5vh, 52px);
    }
    /* a leading visually-hidden heading shouldn't push the first visible
       element down */
    .section__content > .sr-only:first-child + * {
      margin-top: 0;
    }
    /* the value-prop heading, now on the right above its content */
    .section__lead {
      font-size: clamp(1.7rem, 3vw, 2.6rem);
      font-weight: 640;
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--fg);
      max-width: 20ch;
    }
    .section__sub {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--fg-muted);
      max-width: 46ch;
    }
    .section__lead + .section__sub {
      margin-top: clamp(14px, 2vh, 20px);
    }

    /* how it works — a big full-width product demo, steps in a row below.
       The header is left-aligned to the demo edge (label as an eyebrow above
       the lead) so everything in the section shares one left margin. */
    .how__head {
      margin-bottom: clamp(40px, 6vh, 76px);
    }
    .how__head .section__label {
      position: static;
      max-width: none;
      margin-bottom: clamp(12px, 2vh, 18px);
    }
    .steps {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: clamp(28px, 4vh, 44px);
    }
    .step {
      display: grid;
      grid-template-columns: 42px 1fr;
      gap: clamp(12px, 1.6vw, 22px);
      align-items: start;
    }
    .step__n {
      font-size: 1rem;
      font-weight: 700;
      color: var(--sky-deep);
      font-variant-numeric: tabular-nums;
      padding-top: 0.35em;
    }
    .step__k {
      font-size: clamp(1.2rem, 1.6vw, 1.5rem);
      font-weight: 620;
      letter-spacing: -0.02em;
      color: var(--fg);
      margin-bottom: 7px;
    }
    .step__t {
      font-size: 1.02rem;
      line-height: 1.55;
      color: var(--fg-2);
      max-width: 54ch;
    }
    /* the animation can add `is-active` to the matching step to highlight it */
    .step {
      transition: opacity 240ms ease;
    }
    .steps:has(.step.is-active) .step:not(.is-active) {
      opacity: 0.5;
    }
    .step.is-active .step__n {
      color: var(--sky);
    }

    /* the demo viewport — a big, clean screen the animation drops into */
    .how__demo {
      width: 100%;
    }
    .how__demo-screen {
      aspect-ratio: 16 / 9;
      border-radius: var(--r-3);
      background: var(--surface-solid);
      border: 1px solid var(--line-soft);
      box-shadow: var(--e-2);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .how__demo-tag {
      font-size: 0.82rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--fg-muted);
    }
    /* the three steps as a row beneath the demo */
    .steps--row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(28px, 4vw, 56px);
      margin-top: clamp(36px, 5vh, 60px);
    }

    @media (max-width: 760px) {
      .how__head {
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .steps--row {
        grid-template-columns: 1fr;
        gap: clamp(26px, 5vh, 40px);
      }
    }

    /* why — quote is the lead, then reasons */
    .quote {
      position: relative;
      font-size: clamp(1.7rem, 3.2vw, 2.7rem);
      font-weight: 500;
      font-style: italic;
      line-height: 1.16;
      letter-spacing: -0.02em;
      color: var(--fg);
      max-width: 18ch;
    }
    /* hang the mark into the margin so the quote text aligns flush-left with
       the reasons below it */
    .quote__mark {
      position: absolute;
      right: 100%;
      top: 0.02em;
      margin-right: 0.1em;
      color: var(--clay);
      font-style: normal;
    }
    .reasons {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(20px, 2.4vw, 40px);
    }
    @media (max-width: 720px) {
      .reasons {
        grid-template-columns: 1fr;
        gap: clamp(24px, 4vh, 34px);
      }
    }
    .reason__h {
      font-size: 1.1rem;
      font-weight: 620;
      letter-spacing: -0.015em;
      line-height: 1.25;
      color: var(--fg);
      margin-bottom: 9px;
    }
    .reason__t {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--fg-2);
    }

    /* privacy — checkmark points */
    .points {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: clamp(24px, 3.4vh, 38px);
    }
    .point {
      display: grid;
      grid-template-columns: 22px 1fr;
      gap: 16px;
      align-items: start;
    }
    .point__tick {
      width: 20px;
      height: 20px;
      margin-top: 0.12em;
      position: relative;
      flex: 0 0 auto;
    }
    .point__tick::after {
      content: "";
      position: absolute;
      left: 5px;
      top: 1px;
      width: 7px;
      height: 13px;
      border: solid var(--sky-deep);
      border-width: 0 2.5px 2.5px 0;
      transform: rotate(43deg);
    }
    .point__h {
      font-size: 1.1rem;
      font-weight: 620;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin-bottom: 7px;
    }
    .point__t {
      font-size: 1rem;
      line-height: 1.55;
      color: var(--fg-2);
      max-width: 58ch;
    }

    /* faq accordion */
    .faq {
      display: flex;
      flex-direction: column;
    }
    .qa {
      border-top: 1px solid var(--line-faint);
    }
    .qa:last-child {
      border-bottom: 1px solid var(--line-faint);
    }
    .qa__q {
      list-style: none;
      cursor: pointer;
      display: grid;
      grid-template-columns: 38px 1fr 20px;
      align-items: center;
      gap: 14px;
      padding: clamp(18px, 2.6vh, 24px) 0;
      font-size: clamp(1.02rem, 1.4vw, 1.2rem);
      font-weight: 560;
      letter-spacing: -0.015em;
      color: var(--fg);
      transition: color 140ms ease;
    }
    .qa__q::-webkit-details-marker {
      display: none;
    }
    .qa__q:hover {
      color: var(--sky-deep);
    }
    .qa__n {
      font-size: 0.86rem;
      font-weight: 700;
      color: var(--sky-deep);
      font-variant-numeric: tabular-nums;
    }
    .qa__mark {
      position: relative;
      width: 13px;
      height: 13px;
      justify-self: end;
    }
    .qa__mark::before,
    .qa__mark::after {
      content: "";
      position: absolute;
      background: var(--fg-muted);
