---
import Base from "../layouts/Base.astro";
import TopBar from "../components/TopBar.astro";
import MetaFooter from "../components/MetaFooter.astro";
import BetaSignup from "../components/BetaSignup.astro";
import ProductDemo from "../components/ProductDemo.astro";

const title = "Blink: reads your screen, writes the rest";
const description =
  "Blink is a Mac assistant that reads your screen and writes the reply for you: summon it on any thread, it drafts in your voice and inserts the reply straight into the box. Invite-only macOS beta.";

// the three value props. temporarily unrendered: the old "difference"/proofs
// row was cut from the "why" section; revisiting where these belong as a
// separate pass. kept here so the copy isn't lost.
const reasons = [
  {
    h: "sees what you see.",
    t: "the context is already on your screen, so you stop re-explaining yourself to a chatbot.",
  },
  {
    h: "sounds like you, not an ai.",
    t: "drafts in your voice and moves the conversation forward with sharp replies that take the initiative.",
  },
  {
    h: "always there, never in the way.",
    t: "blink follows you window to window, ready the moment you need it and quiet when you don't.",
  },
];

const privacy = [
  {
    h: "asleep until you summon it.",
    t: "the rest of the time blink is idle. no background watching, no always-on recording.",
  },
  {
    h: "only what you point it at.",
    t: "when you ask for a draft, blink reads the conversation in front of you, just then. not your whole screen, not the rest of your day.",
  },
  {
    h: "you stay in control, and you can check.",
    t: "blink writes a draft and stops, you decide what to send. and because it's source-available, you can read exactly what it captures, or run the whole thing yourself.",
  },
];

const faqs = [
  {
    q: "who is blink for?",
    a: "founders living in claude code, their inbox, and x at the same time. creators and influencers buried in dms and replies. if you want to stop context switching, blink's for you.",
  },
  {
    q: "does blink send messages for me?",
    a: "no. it writes the draft into the box. you read it, edit it, and hit send yourself.",
  },
  {
    q: "what apps does it work in?",
    a: "anywhere you type: imessage, slack, gmail, discord, docs, and most native and web apps.",
  },
  {
    q: "can blink see the whole conversation, or just what's on screen?",
    a: "the whole conversation. it doesn't just grab the last few messages you can see, it reads the full thread, so the draft actually has the context.",
  },
  {
    q: "what happens to what blink reads?",
    a: "to write a draft, the text on your screen goes to an ai model. some of it is kept to help us improve blink, and you can turn that off anytime. if you'd rather keep everything on your own machine, blink is source-available to self-host.",
  },
  {
    q: "what will it cost?",
    a: "blink will be a paid product. the beta is hands-on and free while we get it right, and we'll talk pricing with you directly before it ever costs you anything.",
  },
  {
    q: "what do i need to run it?",
    a: "a mac, a couple of permissions (accessibility and screen recording), and a hotkey to summon blink. takes about a minute to set up.",
  },
  {
    q: "windows or iphone?",
    a: "not yet. blink is macOS only for now. join the waitlist and we'll let you know if that changes.",
  },
  {
    q: "is blink available to the public?",
    a: "yes. it's a waitlist for now, only because we onboard everyone ourselves: we set you up, learn how you work, and tune blink to fit. that only works a few people at a time, so we invite in small batches. leave your email and we'll reach out when there's room. the code is public too, so you can read exactly what it does or self-host it today.",
  },
];
---

<Base title={title} description={description}>
  <!-- Set before first paint so reveal elements start hidden (no flash).
       JS-off visitors never get the class, so all content stays visible. -->
  <script is:inline>document.documentElement.classList.add("has-js");</script>

  <TopBar />

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <canvas class="hero__build" aria-hidden="true"></canvas>
      <div class="container hero__inner">
        <h1 class="wordmark reveal">
          <span class="wordmark__text">blink</span><span
            class="cursor"
            aria-hidden="true"></span>
        </h1>
        <p class="tagline reveal">reads your screen,<br />writes the rest.</p>
        <div class="cta-row reveal">
          <a class="btn btn--primary" href="#join">
            <span>join the beta</span>
            <span class="btn__arrow" aria-hidden="true">→</span>
          </a>
          <a class="btn btn--ghost hero__story" href="/blog/what-is-blink">
            <span class="hero__story-label">read the story</span>
          </a>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section how" id="how" aria-labelledby="how-lead">
      <div class="container how__inner">
        <div class="measure how__head">
          <p class="section__label reveal">how it works</p>
          <h2 class="section__lead reveal" id="how-lead">
            blink reads the chat and writes your reply.
          </h2>
        </div>
        <div class="how__demo reveal">
          <ProductDemo />
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="section" id="why" aria-labelledby="why-lead">
      <div class="container section__inner">
        <div class="measure">
          <p class="section__label reveal">why blink</p>
          <div class="why__statement">
            <h2 class="why__hook reveal" id="why-lead">
              you switch tasks<br />every
              <span class="why__stat">24 seconds</span><sup class="why__cite"><a
                  class="why__cite-mark"
                  href="https://hbr.org/2022/08/how-much-time-and-energy-do-we-waste-toggling-between-applications"
                  target="_blank"
                  rel="noopener"
                  aria-label="Source: Harvard Business Review, 2022"
                  aria-describedby="why-cite-note"
                >1</a><span class="why__cite-pop" id="why-cite-note" role="note">harvard business review, 2022. 137 workers toggled between apps ~1,200 times a day.</span></sup>.<br />that's
              <span class="why__stat">four hours a week</span><br />just finding
              your place again.
            </h2>
            <div class="why__body-col">
              <p class="why__body reveal">
                and that's the easy part. the real tax is the reset that
                follows: reminding yourself what you were even doing there, and
                why.
              </p>
              <p class="why__body why__body--lead reveal">
                blink covers the reset. it catches you up the moment you land
                and points at the next step, so the switch barely costs you
                anything.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRIVACY -->
    <section class="section" id="privacy" aria-labelledby="privacy-lead">
      <div class="container section__inner">
        <div class="measure">
          <p class="section__label reveal">privacy</p>
          <div class="privacy__split">
            <div class="privacy__intro">
              <h2 class="section__lead reveal" id="privacy-lead">
                reading your screen, without the creep.
              </h2>
              <p class="section__sub reveal">
                blink reads your screen so you never have to re-explain the
                conversation. here's what that does and doesn't mean.
              </p>
            </div>
            <ul class="points">
              {
                privacy.map((p) => (
                  <li class="point reveal">
                    <span class="point__tick" aria-hidden="true" />
                    <div>
                      <h3 class="point__h">{p.h}</h3>
                      <p class="point__t">{p.t}</p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq" aria-labelledby="faq-lead">
      <div class="container section__inner">
        <div class="measure">
          <p class="section__label reveal">faq</p>
          <div class="section__content">
            <h2 class="section__lead reveal" id="faq-lead">
              questions people actually ask.
            </h2>
            <div class="faq">
              {
                faqs.map((f, i) => (
                  <details class="qa reveal" name="faq">
                    <summary class="qa__q">
                      <span class="qa__n">{String(i + 1).padStart(2, "0")}</span>
                      <span class="qa__text">{f.q}</span>
                      <span class="qa__mark" aria-hidden="true" />
                    </summary>
                    <p class="qa__a">{f.a}</p>
                  </details>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- JOIN -->
    <section class="section join" id="join" aria-labelledby="join-lead">
      <div class="join__card">
        <div class="container">
        <div class="join__inner">
        <h2 class="join__title reveal" id="join-lead">
          blink keeps the threads.<br />you keep your focus.
        </h2>

        <BetaSignup />

        <p class="join__note reveal">
          a macOS beta. on an iphone or a windows pc? blink is mac-only for now.
          drop your email and we'll ping you when you can use it.
        </p>
        </div>
        </div>
      </div>
    </section>
  </main>

  <MetaFooter />

  <style>
    /* ============================================================= *
     * HERO — text only, big and confident
     * ============================================================= */
    .hero {
      position: relative;
      /* An inset rounded card: the painting is framed, floating on the cream
         page. The nav floats over its top (the card rises up under the
         transparent topbar via the negative top margin) so the whole top of
         the page reads as one surface — no full-width strip above a card. */
      --hero-inset: clamp(8px, 1.3vw, 16px);
      margin: var(--hero-inset);
      margin-top: calc(var(--hero-inset) - var(--topbar-h));
      border-radius: clamp(20px, 2.4vw, 34px);
      min-height: calc(100svh - var(--hero-inset) * 2);
      display: flex;
      align-items: center;
      padding-block: clamp(48px, 8vh, 104px);
      overflow: hidden;
      /* shadow as a var so the has-js gating below can hide/restore it without
         duplicating the value. no-JS gets it straight away. */
      --hero-shadow:
        0 1px 0 0 color-mix(in oklch, var(--fg) 4%, transparent),
        0 30px 60px -34px color-mix(in oklch, var(--ink) 45%, transparent);
      box-shadow: var(--hero-shadow);
      transition: box-shadow 700ms ease;
    }
    /* The painting lives only here. A left-heavy cream wash keeps the
       (left-aligned) text legible while the art stays vivid toward the
       right; the card's rounded corners clip it (no bottom fade — the frame
       is the edge now). */
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      background-image: /* soft top scrim — lifts nav legibility over the art */
        linear-gradient(
          to bottom,
          color-mix(in oklch, var(--paper) 52%, transparent) 0,
          transparent var(--topbar-h)
        ),
        /* left-heavy wash — keeps the (left-aligned) hero text legible. lighter
           than before so the painting reads more vivid toward the right. */
          linear-gradient(
            100deg,
            color-mix(in oklch, var(--paper) 64%, transparent) 0%,
            color-mix(in oklch, var(--paper) 38%, transparent) 48%,
            color-mix(in oklch, var(--paper) 16%, transparent) 100%
          ),
        url("/pointilism-3-hd.webp");
      background-size: cover, cover, cover;
      background-position: center top, center top, center top;
      /* push the pointillism's colour — more saturated and a touch punchier */
      filter: saturate(1.32) contrast(1.05);
    }
    /* With JS, the crisp painting starts hidden; the canvas covers it in cream
       and dissolves that cover cell by cell to reveal it. The painting is
       brought to full opacity instantly (.is-painted, set at animation start)
       beneath the cover — the canvas, not a CSS fade, drives the reveal.
       No-JS / reduced-motion keep the painting visible from the start. */
    :global(html.has-js) .hero::before {
      opacity: 0;
    }
    /* With JS, hold the card flat (no shadow) while it paints in; the shadow
       fades in when the reveal completes (.is-revealed). No-JS keeps it. */
    :global(html.has-js) .hero {
      box-shadow: 0 1px 0 0 transparent, 0 30px 60px -34px transparent;
    }
    :global(html.has-js) .hero.is-painted.is-revealed {
      box-shadow: var(--hero-shadow);
    }
    :global(html.has-js) .hero.is-painted::before {
      opacity: 1;
    }
    /* canvas that paints the dots in, on top of the (hidden) painting,
       below the text */
    .hero__build {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }
    @media (prefers-reduced-motion: reduce) {
      :global(html.has-js) .hero::before {
        opacity: 1;
        transition: none;
      }
    }
    .hero__inner {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(20px, 2.6vh, 30px);
    }
    .wordmark {
      font-size: clamp(5rem, 16vw, 15rem);
      font-weight: 760;
      line-height: 0.82;
      letter-spacing: -0.045em;
      color: var(--fg);
      display: inline-flex;
      align-items: baseline;
    }
    .cursor {
      display: inline-block;
      width: 0.07em;
      height: 0.66em;
      background: var(--sky);
      margin-left: 0.06em;
      border-radius: 1px;
      /* hidden until the painting has finished fading in (.is-revealed) — then
         it fades up and starts blinking, so it reads as the cursor "arriving"
         once the wordmark has fully landed. */
      opacity: 0;
    }
    .hero.is-revealed .cursor {
      animation:
        caret-arrive 360ms ease forwards,
        caret-blink 1.1s steps(2, jump-none) 360ms infinite;
    }
    @keyframes caret-arrive {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
    @keyframes caret-blink {
      0%,
      50% {
        opacity: 1;
      }
      50.01%,
      100% {
        opacity: 0;
      }
    }
    .tagline {
      font-size: var(--fs-h3);
      font-weight: 560;
      line-height: 1.1;
      letter-spacing: -0.025em;
      color: var(--fg);
    }
    .cta-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 22px;
      margin-top: 8px;
    }
    /* plain text, no box, no underline, no arrow — bare dark text on the
       painting was hard to read, so the heavier weight + a strong cream halo
       lift it off the art while keeping the affordance as quiet as possible. */
    .hero__story.btn--ghost {
      color: var(--fg);
      font-weight: 600;
      text-shadow:
        0 0 2px color-mix(in oklch, var(--paper) 95%, transparent),
        0 0 8px color-mix(in oklch, var(--paper) 88%, transparent),
        0 0 18px color-mix(in oklch, var(--paper) 78%, transparent),
        0 1px 24px color-mix(in oklch, var(--paper) 60%, transparent);
    }
    .hero__story.btn--ghost:hover {
      color: var(--fg);
    }

    /* ============================================================= *
     * SECTION — eyebrow label above full-width content
     * ============================================================= */
    .section {
      position: relative;
      padding-block: clamp(72px, 11vh, 150px);
    }
    /* No dividers or bands between sections — separation is carried by the
       generous section padding (whitespace) alone. */
    .section__inner {
      /* full container width, left-aligned at the gutter — same footprint as
         the "how it works" section, so every section lines up on the same edge
         instead of a narrow column floating mid-page. */
      display: block;
    }
    /* the shared reading column: prose sits in a centered ~700px measure inside
       the wide container, so text stops stranding against the left gutter with
       an empty right half. full-bleed elements (the product demo) opt out. */
    .measure {
      max-width: var(--measure);
      margin-inline: auto;
    }
    .measure--wide {
      max-width: var(--measure-wide);
    }
    /* the section name as a small eyebrow above the content (same pattern as
       "how it works") — the old sticky left rail squeezed the headings into a
       cramped column and forced ugly wraps, so it's gone. */
    .section__label {
      font-size: var(--fs-eyebrow);
      font-weight: 680;
      letter-spacing: -0.02em;
      line-height: 1.12;
      color: var(--fg);
      margin-bottom: clamp(18px, 2.6vh, 28px);
    }
    .section__content {
      max-width: none;
    }
    .section__content > * + * {
      margin-top: clamp(30px, 4.5vh, 52px);
    }
    /* a leading visually-hidden heading shouldn't push the first visible
       element down */
    .section__content > .sr-only:first-child + * {
      margin-top: 0;
    }
    /* the value-prop heading — full measure now, with balanced line breaks */
    .section__lead {
      font-size: var(--fs-h2);
      font-weight: 640;
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--fg);
      max-width: 24ch;
      text-wrap: balance;
    }
    .section__sub {
      font-size: var(--fs-body);
      line-height: 1.55;
      color: var(--fg-muted);
      max-width: 46ch;
    }
    .section__lead + .section__sub {
      margin-top: clamp(14px, 2vh, 20px);
    }

    /* how it works — a big full-width product demo, steps in a row below.
       The header is left-aligned to the demo edge (label as an eyebrow above
       the lead) so everything in the section shares one left margin. */
    .how__head {
      margin-bottom: clamp(40px, 6vh, 76px);
    }
    .how__head .section__label {
      position: static;
      max-width: none;
      margin-bottom: clamp(12px, 2vh, 18px);
    }
    /* the live product-demo animation spans the section; it owns its own frame
       and step track (ProductDemo.astro). */
    .how__demo {
      width: 100%;
    }

    @media (max-width: 860px) {
      .how__head {
        grid-template-columns: 1fr;
        gap: 10px;
      }
    }

    /* why — the value-prop section, the emotional core of the page. one
       vertical narrative: the stat statement up top, then the proof of how
       blink answers it. (was a hook|body two-column split, which made the
       stat and its resolution read side-by-side instead of as one thought.) */
    .why__hook {
      font-size: clamp(1.75rem, 4.2vw, 3.3rem);
      font-weight: 600;
      line-height: 1.12;
      letter-spacing: -0.035em;
      color: var(--fg);
      /* line breaks are authored explicitly (<br>) for the intended rhythm */
    }
    /* the numbers are the whole argument — colour them so the eye lands on
       them first and the dense hook reads as two stats, not four lines. */
    .why__stat {
      color: var(--sky-deep);
    }
    /* citation as a hover/focus footnote on the first stat: a small superscript
       marker that expands the source on mouseover, instead of a separate line
       of body copy under the hook. */
    .why__cite {
      position: relative;
      font-size: 0.34em;
      font-weight: 680;
      line-height: 0;
      margin-left: 0.12em;
      vertical-align: super;
    }
    .why__cite-mark {
      color: var(--sky-deep);
      text-decoration: none;
      border-bottom: 1px dotted
        color-mix(in oklch, var(--sky-deep) 55%, transparent);
      cursor: help;
    }
    .why__cite-pop {
      position: absolute;
      left: 0;
      bottom: calc(100% + 9px);
      width: max-content;
      max-width: 244px;
      padding: 10px 12px;
      border-radius: var(--r-2);
      background: var(--surface-solid);
      border: 1px solid var(--line-soft);
      box-shadow: var(--e-2);
      font-size: 0.8rem;
      font-weight: 400;
      line-height: 1.45;
      letter-spacing: 0;
      color: var(--fg-2);
      opacity: 0;
      transform: translateY(4px);
      pointer-events: none;
      transition: opacity 0.16s ease, transform 0.16s ease;
      z-index: 5;
    }
    .why__cite:hover .why__cite-pop,
    .why__cite:focus-within .why__cite-pop {
      opacity: 1;
      transform: translateY(0);
    }
    /* the marker sits far right on its line; on narrow screens a left-anchored
       popover would run off the right edge, so flip it to open leftward. */
    @media (max-width: 560px) {
      .why__cite-pop {
        left: auto;
        right: 0;
      }
    }
    /* the cost copy sits under the hook in the same centered column, flush to
       the same left edge as the eyebrow and hook above it. */
    .why__body-col {
      display: grid;
      gap: clamp(14px, 2vh, 22px);
      margin-top: clamp(22px, 3.2vh, 38px);
    }
    .why__body {
      font-size: var(--fs-lead);
      line-height: 1.55;
      color: var(--fg-2);
    }
    /* the turn, "blink covers the reset", carries full ink so the answer
       lands a shade stronger than the setup above it. */
    .why__body--lead {
      color: var(--fg);
    }

    /* privacy — a single centered column like every other section: the intro
       stacked above the checklist, so the whole page shares one left edge
       instead of widening out into a two-column block here. */
    .privacy__split {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(26px, 4vh, 42px);
    }
    .privacy__intro > * + * {
      margin-top: clamp(14px, 2vh, 20px);
    }
    /* checkmark points — a vertical checklist */
    .points {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: clamp(22px, 3vh, 34px);
    }
    .point {
      display: grid;
      grid-template-columns: 22px 1fr;
      gap: 16px;
      align-items: start;
    }
    .point__tick {
      width: 20px;
      height: 20px;
      margin-top: 0.12em;
      position: relative;
      flex: 0 0 auto;
    }
    .point__tick::after {
      content: "";
      position: absolute;
      left: 5px;
      top: 1px;
      width: 7px;
      height: 13px;
      border: solid var(--sky-deep);
      border-width: 0 2.5px 2.5px 0;
      transform: rotate(43deg);
    }
    .point__h {
      font-size: var(--fs-h4);
      font-weight: 620;
      letter-spacing: -0.015em;
      color: var(--fg);
      margin-bottom: 7px;
    }
    .point__t {
      font-size: var(--fs-body);
      line-height: 1.55;
      color: var(--fg-2);
    }

    /* faq accordion */
    .faq {
      display: flex;
      flex-direction: column;
    }
    .qa {
      border-top: 1px solid var(--line-faint);
    }
    .qa:last-child {
      border-bottom: 1px solid var(--line-faint);
    }
    .qa__q {
      list-style: none;
      cursor: pointer;
      display: grid;
      grid-template-columns: 38px 1fr 20px;
      align-items: center;
      gap: 14px;
      padding: clamp(18px, 2.6vh, 24px) 0;
      font-size: var(--fs-lead);
      font-weight: 560;
      letter-spacing: -0.015em;
      color: var(--fg);
      transition: color 140ms ease;
    }
    .qa__q::-webkit-details-marker {
      display: none;
    }
    .qa__q:hover {
      color: var(--sky-deep);
    }
    .qa__n {
      font-size: var(--fs-small);
      font-weight: 700;
      color: var(--sky-deep);
      font-variant-numeric: tabular-nums;
    }
    .qa__mark {
      position: relative;
      width: 13px;
      height: 13px;
      justify-self: end;
    }
    .qa__mark::before,
    .qa__mark::after {
      content: "";
      position: absolute;
      background: var(--fg-muted);
      transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
        opacity 160ms ease;
    }
    .qa__mark::before {
      left: 0;
      top: 6px;
      width: 13px;
      height: 1.5px;
    }
    .qa__mark::after {
      left: 6px;
      top: 0;
      width: 1.5px;
      height: 13px;
    }
    .qa[open] .qa__mark::after {
      transform: scaleY(0);
      opacity: 0;
    }
    .qa__a {
      grid-column: 1 / -1;
      padding: 0 0 clamp(18px, 2.6vh, 24px) 52px;
      font-size: var(--fs-body);
      line-height: 1.6;
      color: var(--fg-2);
      max-width: 66ch;
    }
    .qa[open] .qa__a {
      animation: qa-in 260ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes qa-in {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
    }

    /* ============================================================= *
     * JOIN — the closer, an inset card
     * ============================================================= */
    /* Same rounded-card language as the hero and the demo, just inverted to a
       deep-ink ground for a focused conversion moment — an inset card, not a
       full-bleed banner, so it sits consistently with everything above it. */
    .section.join {
      background: transparent;
      padding-block: clamp(36px, 6vh, 84px);
    }
    .join__card {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      margin-inline: clamp(8px, 1.3vw, 18px);
      border-radius: clamp(20px, 2.4vw, 34px);
      background: var(--ink);
      color: color-mix(in oklch, var(--paper) 72%, transparent);
      padding-block: clamp(84px, 16vh, 184px);
      box-shadow:
        0 1px 0 0 color-mix(in oklch, var(--fg) 4%, transparent),
        0 34px 64px -36px color-mix(in oklch, var(--ink) 60%, transparent);
    }
    /* the pointillism, integrated as a saturated dark ground: a deep-ink veil
       (heaviest at the top-left, behind the title) lets the painting's blues
       glow through toward the open lower-right, instead of a flat ink fill. */
    .join__card::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      background-image: linear-gradient(
          120deg,
          color-mix(in oklch, var(--ink) 95%, transparent) 0%,
          color-mix(in oklch, var(--ink) 83%, transparent) 46%,
          color-mix(in oklch, var(--ink) 58%, transparent) 100%
        ),
        url("/pointilism-3-hd.webp");
      background-size: cover, cover;
      /* drop the painting's crop down so the child in the lower-left hills sits
         in view, rather than the centred tree/hills band */
      background-position: center, center 97%;
      filter: saturate(1.3);
    }
    .join__card > .container {
      position: relative;
      z-index: 1;
    }
    .join__inner {
      max-width: 820px;
    }
    .join__title {
      font-size: var(--fs-display);
      font-weight: 680;
      line-height: 1;
      letter-spacing: -0.035em;
      color: var(--paper);
      margin-bottom: clamp(38px, 5.5vh, 56px);
    }
    .join__note {
      font-size: var(--fs-small);
      line-height: 1.5;
      color: color-mix(in oklch, var(--paper) 60%, transparent);
      max-width: 54ch;
      margin-top: 18px;
    }
    /* a clear break between the signup pill and the supporting notes (the
       first note is the first <p> in .join__inner). second note stays at 18px. */
    .join__note:first-of-type {
      margin-top: clamp(34px, 5vh, 56px);
    }
    /* signup form markup, behavior, and styling live in BetaSignup.astro */

    /* ============================================================= *
     * Reveal-on-scroll (progressive enhancement; no-JS shows all)
     * ============================================================= */
    :global(html.has-js) .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 720ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 720ms cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--reveal-delay, 0ms);
      will-change: opacity, transform;
    }
    :global(html.has-js) .reveal.in {
      opacity: 1;
      transform: none;
    }
    /* the hero wordmark settles in slower and from further — a deliberate
       arrival rather than a quick fade. */
    :global(html.has-js) .wordmark.reveal {
      transform: translateY(34px) scale(0.985);
      transition-duration: 940ms;
    }
    :global(html.has-js) .wordmark.reveal.in {
      transform: none;
    }

    /* ============================================================= *
     * RESPONSIVE
     * ============================================================= */
    @media (max-width: 560px) {
      .qa__a {
        padding-left: 0;
      }
    }

    /* On phones the framed look stops paying for itself — screen real estate is
       too tight to spend on insets, and the vertical rhythm is far too loose.
       So: hero + join go full-bleed (edge to edge, no rounded card or shadow),
       and the generous desktop section spacing tightens up. */
    @media (max-width: 640px) {
      .hero {
        --hero-inset: 0px;
        --hero-shadow: none;
        border-radius: 0;
      }
      /* ~110px of dead space between sections (109px top + bottom) is too much
         on a phone; tighten to a calmer mobile rhythm. */
      .section {
        padding-block: clamp(44px, 8vh, 60px);
      }
      /* the closing card goes full-bleed too, so the page reads as one surface
         top (hero) to bottom (join) instead of floating chips on cream. */
      .join__card {
        margin-inline: 0;
        border-radius: 0;
        padding-block: clamp(56px, 10vh, 92px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .cursor {
        animation: none;
        opacity: 1;
      }
      .qa[open] .qa__a {
        animation: none;
      }
      :global(html.has-js) .reveal,
      :global(html.has-js) .wordmark.reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>

  <!-- Hero: reconstruct the painting from its own pixels as one wave fanning
       out from the tree. The crisp art sits under a cream cover; the wave
       dissolves that cover cell by cell, each cell doing cream → pointillist
       dot → crisp painting in one coupled motion (no global "image appears"). -->
  <script type="module">
    const hero = document.querySelector(".hero");
    const canvas = hero?.querySelector(".hero__build");
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const paint = () => hero?.classList.add("is-painted");
    // marks the reveal as fully settled — gates the caret so it only starts
    // blinking once the painting has finished fading in.
    const revealed = () => hero?.classList.add("is-revealed");

    if (!hero || !canvas || !canvas.getContext || reduce) {
      paint();
      revealed();
      canvas?.remove();
    } else {
      const ctx = canvas.getContext("2d");
      // One wave, fully coupled. The crisp painting sits beneath a solid cream
      // cover (this canvas) from the start. As the wave passes a cell it does
      // ONE motion: a pointillist dot pops in on the cream, then melts away as
      // that cell's cover dissolves to reveal the crisp art beneath. Cream →
      // dot → painting happens locally, per cell, on a single clock — so there
      // is no second "image appears all at once" event. Order is radial from
      // the tree, so it fans evenly rather than bursting from the middle.
      // END ≈ the slowest cell's finish in wave-units (max aS+aD ≈ 0.97+0.44).
      // Matching it (not overshooting to 1.7) means the eased clock's slow-OUT
      // lands while the last cells are still melting in — so the reveal reads
      // slow → fast → slow, instead of slow → fast then a dead tail.
      const END = 1.43;
      let raf = 0,
        done = false,
        dots = [],
        w = 0,
        h = 0,
        t0 = 0,
        cream = [242, 240, 233],
        creamCss = "rgb(242,240,233)";

      const cleanup = () => {
        if (done) return;
        done = true;
        clearTimeout(failsafe);
        if (raf) cancelAnimationFrame(raf);
        paint();
        revealed();
        canvas.remove();
      };
      const failsafe = setTimeout(cleanup, 6000);
      const easeOut = (p) => 1 - Math.pow(1 - p, 3);
      // ease the master clock so the reveal eases in gently (a slow initial
      // fade-out) and settles out, rather than starting at full pace.
      const easeInOut = (p) =>
        p < 0.5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2;
      const DURATION = 2.2; // real seconds; mapped onto the END wave timeline
      const clamp01 = (v) => (v < 0 ? 0 : v > 1 ? 1 : v);

      const render = (t) => {
        // Lay down the cream cover: it hides the crisp painting beneath until
        // the wave dissolves it, cell by cell.
        ctx.globalCompositeOperation = "source-over";
        ctx.globalAlpha = 1;
        ctx.fillStyle = creamCss;
        ctx.fillRect(0, 0, w, h);

        // Dissolve the cover where the wave has passed — a growing hole per
        // cell punches through to the crisp art. Holes overlap at full open so
        // no cream lattice is left behind (erasing overlap is invisible).
        ctx.globalCompositeOperation = "destination-out";
        for (const d of dots) {
          if (t < d.aS) continue;
          const e = easeOut(clamp01((t - d.aS) / d.aD));
          ctx.globalAlpha = e;
          ctx.beginPath();
          ctx.arc(d.x, d.y, d.hr * e, 0, 6.2832);
          ctx.fill();
        }

        // The pointillist dot itself: pops in on the cream, then melts to 0 as
        // its hole opens and the crisp art takes over. Same clock as the hole,
        // so cream → dot → painting is one coupled motion for each cell.
        ctx.globalCompositeOperation = "source-over";
        for (const d of dots) {
          if (t < d.aS) continue;
          const p = clamp01((t - d.aS) / d.aD);
          // pop to FULL strength fast, hold, then melt to 0 over the last ~45%
          // as the crisp art (revealed through the hole) takes the cell over
          const a = p < 0.55 ? clamp01(p * 4) : clamp01((1 - p) / 0.45);
          ctx.globalAlpha = a;
          const r = d.r0 + (d.fr - d.r0) * easeOut(p);
          ctx.beginPath();
          ctx.arc(d.x, d.y, r, 0, 6.2832);
          ctx.fillStyle = d.c;
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        ctx.globalCompositeOperation = "source-over";
      };

      const frame = (now) => {
        const p = clamp01((now - t0) / 1000 / DURATION);
        render(easeInOut(p) * END); // eased clock → slow, gentle onset
        if (p >= 1) cleanup();
        else raf = requestAnimationFrame(frame);
      };

      const start = () => {
        const rect = hero.getBoundingClientRect();
        w = rect.width;
        h = rect.height;
        if (w <= 0 || h <= 0) {
          cleanup();
          return;
        }
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        // cream tint = the page background, resolved to rgb. (Chrome reports
        // background-color back as oklch, so parse it through a canvas.)
        try {
          const pc = document.createElement("canvas").getContext("2d");
          pc.fillStyle = getComputedStyle(document.body).backgroundColor;
          pc.fillRect(0, 0, 1, 1);
          const px = pc.getImageData(0, 0, 1, 1).data;
          if (px[0] + px[1] + px[2] > 360) cream = [px[0], px[1], px[2]];
        } catch (e) {}
        creamCss = `rgb(${cream[0]},${cream[1]},${cream[2]})`;

        // sample the painting (cover-fit, top-anchored) at quarter res
        const sw = Math.max(1, Math.round(w * 0.25));
        const sh = Math.max(1, Math.round(h * 0.25));
        const off = document.createElement("canvas");
        off.width = sw;
        off.height = sh;
        const octx = off.getContext("2d");
        const ir = img.naturalWidth / img.naturalHeight;
        const fr = sw / sh;
        let dw, dh;
        if (ir > fr) {
          dh = sh;
          dw = sh * ir;
        } else {
          dw = sw;
          dh = sw / ir;
        }
        octx.drawImage(img, (sw - dw) / 2, 0, dw, dh);
        const data = octx.getImageData(0, 0, sw, sh).data;

        const gap = Math.max(11, Math.round(Math.sqrt((w * h) / 6000)));
        // Overscan the grid by one cell on every side so the dots + erase-holes
        // cover the canvas all the way to its edges; the canvas clips the
        // overhang to a clean rectangle instead of leaving the scalloped edges
        // of the border circles showing along the bottom and sides.
        const xs = [];
        for (let x = gap / 2 - gap; x < w + gap; x += gap) xs.push(x);
        const ys = [];
        for (let y = gap / 2 - gap; y < h + gap; y += gap) ys.push(y);
        const cols = xs.length,
          rows = ys.length;
        const raw = [];
        // cool-weighted centroid of the upper canvas → the dense blue tree mass,
        // which is where the wave starts (no hand-traced geometry).
        let cwx = 0,
          cwy = 0,
          cwt = 0;
        for (let ry = 0; ry < rows; ry++) {
          const y = ys[ry];
          for (let cx = 0; cx < cols; cx++) {
            const x = xs[cx];
            const sx = Math.max(0, Math.min(sw - 1, ((x / w) * sw) | 0));
            const sy = Math.max(0, Math.min(sh - 1, ((y / h) * sh) | 0));
            const i = (sy * sw + sx) * 4;
            const cr = data[i],
              cg = data[i + 1],
              cb = data[i + 2];
            const lum = 0.299 * cr + 0.587 * cg + 0.114 * cb;
            // read the painting at this cell:
            const cool = Math.max(0, Math.min(1, (cb - cr) / 85)); // blue/teal
            const warm = Math.max(0, Math.min(1, (cr - cb) / 80)); // orange/peach
            const bright = Math.max(0, Math.min(1, (lum - 150) / 105)); // cream
            if (x >= 0 && x < w && y >= 0 && y < h * 0.62) {
              const cw = cool * cool;
              cwx += cw * x;
              cwy += cw * y;
              cwt += cw;
            }
            // bake the left-heavy cream wash (matches .hero::before) into the
            // colour, so the left reads light and the cross-fade is seamless
            const wf = 0.72 - 0.4 * (x / w);
            raw.push({
              x,
              y,
              r0: gap * 0.16, // a small dot when it lands
              fr: gap * 0.46, // the visible dot grows to here — transient and
              // fades out, so no fish-scale from overlapping opaque dots
              hr: gap * 0.78, // the cover-erase hole grows past the cell corner
              // (≈ half-diagonal) so the reveal leaves no cream lattice
              c: `rgb(${Math.round(cr + (cream[0] - cr) * wf)},${Math.round(
                cg + (cream[1] - cg) * wf,
              )},${Math.round(cb + (cream[2] - cb) * wf)})`,
              cool,
              warm,
              bright,
            });
          }
        }
        // wave origin = the cool-weighted centroid (the blue tree), floored to
        // the right half so it always starts from the tree side.
        const seedX = Math.max(w * 0.58, cwt > 0 ? cwx / cwt : w * 0.72);
        const seedY = cwt > 0 ? cwy / cwt : h * 0.42;
        // Colour-led sweep: starts at the tree and elongates toward the warm
        // sunset corner (which trails last). radial spreads it evenly (so no
        // corner is starved), proj gives the diagonal sweep, and the colour term
        // makes the cool blues lead while the warm corner resolves last.
        const diag = Math.hypot(w, h) || 1;
        const cornerX = w * 0.06,
          cornerY = h * 0.08;
        let vx = cornerX - seedX,
          vy = cornerY - seedY;
        const vlen = Math.hypot(vx, vy) || 1;
        vx /= vlen;
        vy /= vlen;
        let minO = Infinity,
          maxO = -Infinity;
        for (const d of raw) {
          const radial = Math.hypot(d.x - seedX, d.y - seedY) / diag;
          const proj = Math.max(
            0,
            ((d.x - seedX) * vx + (d.y - seedY) * vy) / diag,
          );
          const colour = d.warm * 0.5 + d.bright * 0.3 - d.cool * 0.2;
          d.o = radial * 0.42 + proj * 0.5 + colour * 0.3;
          if (d.o < minO) minO = d.o;
          if (d.o > maxO) maxO = d.o;
        }
        const spanO = maxO - minO || 1;
        const WAVE_SPAN = 0.95;
        for (const d of raw) {
          const t = (d.o - minO) / spanO; // 0 = tree/first, 1 = warm corner
          d.aS = Math.max(0, WAVE_SPAN * t + (Math.random() - 0.5) * 0.04);
          d.aD = 0.22 + Math.random() * 0.22;
        }
        dots = raw;
        // Cover the hero with cream BEFORE revealing the crisp art beneath, so
        // there's no flash: the canvas hides the painting until the wave
        // dissolves it. .is-painted brings .hero::before to full opacity now,
        // not at the end.
        ctx.fillStyle = creamCss;
        ctx.fillRect(0, 0, w, h);
        paint();
        t0 = performance.now();
        raf = requestAnimationFrame(frame);
      };

      const img = new Image();
      img.decoding = "async";
      img.onload = () => {
        try {
          start();
        } catch (e) {
          cleanup();
        }
      };
      img.onerror = cleanup;
      // Sample the SMALL original for the reveal (it only samples at ~quarter
      // res, so the HD's weight would just stall the animation's onload). The
      // crisp HD is the .hero::before the reveal lands on — same crop/aspect,
      // so the dots still line up.
      img.src = "/pointilism-3.webp";
    }
  </script>

  <!-- Reveal-on-scroll (has-js is already set pre-paint in the head) -->
  <script type="module">
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const items = Array.from(document.querySelectorAll(".reveal"));
    if (reduce || !("IntersectionObserver" in window)) {
      items.forEach((el) => el.classList.add("in"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target;
            // stagger siblings within a block for a bit of choreography
            const sibs = Array.from(
              el.parentElement?.querySelectorAll(":scope > .reveal") || [el],
            );
            const i = Math.max(0, sibs.indexOf(el));
            el.style.setProperty("--reveal-delay", `${Math.min(i, 6) * 90}ms`);
            el.classList.add("in");
            io.unobserve(el);
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
      );
      items.forEach((el) => io.observe(el));
      // Failsafe: never leave content hidden if the observer misbehaves.
      setTimeout(() => items.forEach((el) => el.classList.add("in")), 2200);
    }
  </script>

