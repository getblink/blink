---
import { getCollection } from "astro:content";
import { CLUSTERS } from "../../content.config";
import Base from "../../layouts/Base.astro";
import TopBar from "../../components/TopBar.astro";
import MetaFooter from "../../components/MetaFooter.astro";

const title = "Blog — Blink";
const description =
  "Notes, benchmarks, and teardowns from building Blink — a Mac assistant that reads your screen and writes the rest.";

// Drafts render in local dev for preview, excluded from production builds.
const posts = (
  await getCollection("blog", ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// UTC to match the <time datetime> attr — see note in ArticleLayout. A bare
// YYYY-MM-DD frontmatter date is UTC midnight; local formatting would shift it.
const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    timeZone: "UTC",
    year: "numeric",
    month: "short",
    day: "numeric",
  });

// Group by cluster, preserving the cluster declaration order from CLUSTERS so
// the page layout is stable regardless of publish order. Empty clusters drop.
const grouped = Object.keys(CLUSTERS)
  .map((key) => ({
    key,
    label: CLUSTERS[key],
    posts: posts.filter((p) => p.data.cluster === key),
  }))
  .filter((group) => group.posts.length > 0);
---

<Base title={title} description={description}>
  <TopBar />

  <main class="blogpage">
    <div class="container blog">
      <header class="blog__head">
        <h1>blog</h1>
        <p class="blog__lede muted">
          notes, benchmarks, and teardowns from building blink.
        </p>
      </header>

      {
        grouped.length === 0 ? (
          <p class="blog__empty muted">first post coming soon.</p>
        ) : (
          grouped.map((group) => (
            <section class="cluster">
              <h2 class="cluster__label">{group.label}</h2>
              <ul class="post-list">
                {group.posts.map((post) => (
                  <li class="post-item">
                    <a class="post-item__link" href={`/blog/${post.id}/`}>
                      <span class="post-item__title">{post.data.title}</span>
                      <span class="post-item__desc muted">
                        {post.data.description}
                      </span>
                    </a>
                    <time
                      class="post-item__date muted"
                      datetime={post.data.publishedAt.toISOString()}
                    >
                      {fmtDate(post.data.publishedAt)}
                    </time>
                  </li>
                ))}
              </ul>
            </section>
          ))
        )
      }
    </div>
  </main>

  <MetaFooter />

  <style>
    .blogpage {
      padding-block: clamp(48px, 8vh, 104px) clamp(64px, 10vh, 128px);
    }
    .blog {
      max-width: 760px;
    }

    .blog__head {
      margin-bottom: 56px;
    }
    .blog h1 {
      font-size: var(--fs-prose-h1);
      font-weight: 720;
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 14px;
      color: var(--fg);
    }
    .blog__lede {
      font-size: var(--fs-lead);
      line-height: 1.6;
    }
    .blog__empty {
      font-size: var(--fs-body);
    }

    .cluster {
      margin-bottom: 52px;
    }
    .cluster:last-child {
      margin-bottom: 0;
    }
    .cluster__label {
      font-size: var(--fs-2xs);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--fg-muted);
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line-faint);
    }

    .post-list {
      list-style: none;
      display: grid;
      gap: 30px;
    }
    .post-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 6px 24px;
      align-items: baseline;
    }
    .post-item__link {
      display: grid;
      gap: 6px;
    }
    .post-item__title {
      font-size: var(--fs-prose-h3);
      font-weight: 680;
      letter-spacing: -0.02em;
      color: var(--fg);
      line-height: 1.3;
      width: fit-content;
      border-bottom: 1px solid transparent;
      transition: border-color 140ms ease;
    }
    .post-item__link:hover .post-item__title {
      border-bottom-color: var(--fg);
    }
    .post-item__desc {
      font-size: var(--fs-small);
      line-height: 1.55;
      text-wrap: pretty;
    }
    .post-item__date {
      font-size: var(--fs-xs);
      white-space: nowrap;
    }

    @media (max-width: 680px) {
      .post-item {
        grid-template-columns: 1fr;
        gap: 5px;
      }
      .post-item__date {
        order: -1;
        font-size: var(--fs-xs);
      }
    }
  </style>
</Base>
