---
import { getCollection } from "astro:content";
import { CLUSTERS } from "../../content.config";
import Base from "../../layouts/Base.astro";
import MetaFooter from "../../components/MetaFooter.astro";
import BrandMark from "../../components/BrandMark.astro";

const title = "Blog — Blink";
const description =
  "Notes, benchmarks, and teardowns from building Blink — a local-first Mac assistant that reads your screen and writes the rest.";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

// Group by cluster, preserving the cluster declaration order from CLUSTERS so
// the page layout is stable regardless of publish order. Empty clusters drop.
const grouped = Object.keys(CLUSTERS)
  .map((key) => ({
    key,
    label: CLUSTERS[key],
    posts: posts.filter((p) => p.data.cluster === key),
  }))
  .filter((group) => group.posts.length > 0);
---

<Base title={title} description={description}>
  <main class="shell shell--scroll">
    <header class="row meta">
      <a class="cell" href="/">
        <BrandMark />
        <span>blink</span>
      </a>
      <div class="cell muted">blog</div>
      <div class="cell right muted">{posts.length} {posts.length === 1 ? "post" : "posts"}</div>
    </header>

    <section class="row article-row">
      <div class="cell article-cell">
        <div class="blog">
          <h1>blog</h1>
          <p class="blog__lede">
            notes, benchmarks, and teardowns from building blink.
          </p>

          {
            grouped.length === 0 ? (
              <p class="blog__empty muted">first post coming soon.</p>
            ) : (
              grouped.map((group) => (
                <section class="cluster">
                  <h2 class="cluster__label">{group.label}</h2>
                  <ul class="post-list">
                    {group.posts.map((post) => (
                      <li class="post-item">
                        <a class="post-item__link" href={`/blog/${post.id}`}>
                          <span class="post-item__title">{post.data.title}</span>
                          <span class="post-item__desc muted">
                            {post.data.description}
                          </span>
                        </a>
                        <time
                          class="post-item__date muted"
                          datetime={post.data.publishedAt.toISOString()}
                        >
                          {fmtDate(post.data.publishedAt)}
                        </time>
                      </li>
                    ))}
                  </ul>
                </section>
              ))
            )
          }
        </div>
      </div>
    </section>

    <MetaFooter />
  </main>

  <style>
    header a.cell {
      border-bottom: 0;
    }

    .article-row {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .article-cell {
      padding: clamp(48px, 7vh, 88px) clamp(28px, 5vw, 64px)
        clamp(64px, 9vh, 112px);
      align-items: flex-start;
      justify-content: center;
    }

    .blog {
      width: 100%;
      max-width: 680px;
    }

    .blog h1 {
      font-size: clamp(40px, 5.5vw, 64px);
      font-weight: 700;
      letter-spacing: -0.045em;
      line-height: 1;
      margin-bottom: 16px;
      color: var(--fg);
    }

    .blog__lede {
      font-size: clamp(16px, 1.4vw, 19px);
      color: var(--fg-muted);
      line-height: 1.55;
      margin-bottom: 48px;
    }

    .blog__empty {
      font-size: 16px;
    }

    .cluster {
      margin-bottom: 48px;
    }

    .cluster:last-child {
      margin-bottom: 0;
    }

    .cluster__label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--fg-muted);
      margin-bottom: 18px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--line-soft);
    }

    .post-list {
      list-style: none;
      display: grid;
      gap: 28px;
    }

    .post-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 20px;
      align-items: baseline;
    }

    .post-item__link {
      display: grid;
      gap: 5px;
      border-bottom: 0;
    }

    .post-item__link:hover {
      border-bottom: 0;
    }

    .post-item__title {
      font-size: clamp(18px, 1.6vw, 21px);
      font-weight: 600;
      letter-spacing: -0.015em;
      color: var(--fg);
      line-height: 1.3;
    }

    .post-item__link:hover .post-item__title {
      color: var(--fg);
      border-bottom: 1px solid var(--fg);
      width: fit-content;
    }

    .post-item__desc {
      font-size: clamp(14px, 1.1vw, 15px);
      line-height: 1.5;
      text-wrap: pretty;
    }

    .post-item__date {
      font-size: 13px;
      white-space: nowrap;
    }

    @media (max-width: 880px) {
      .article-cell {
        padding: 40px 20px 64px;
      }

      .post-item {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .post-item__date {
        order: -1;
        font-size: 12px;
      }
    }
  </style>
</Base>
