# Optional: override the client-side beta signup endpoint. Defaults to the
# production Railway URL embedded in the page if unset.
PUBLIC_BETA_SIGNUP_URL=https://blink-production-7b5a.up.railway.app/v1/beta-signup

# Optional: hosted MP4 URLs for the first-viewport demo. Two separate vars
# so each viewport can ship a different clip — both should be 3:4 portrait.
# Desktop renders as a 3:4 cell next to the wordmark; mobile renders as a
# 3:4 (object-fit: contain, centered) cell that fills the remaining
# vertical space below the wordmark+form. Each var accepts a comma-separated
# list; the page cycles through them. If unset, the corresponding slot
# renders a "demo coming soon" placeholder.
PUBLIC_DEMO_VIDEO_URL_DESKTOP=https://downloads.useblink.dev/demo-desktop.mp4
PUBLIC_DEMO_VIDEO_URL_MOBILE=https://downloads.useblink.dev/demo-mobile.mp4

# PostHog product analytics (browser-side). Without PUBLIC_POSTHOG_KEY set, the
# SDK no-ops at runtime so dev builds stay clean.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
