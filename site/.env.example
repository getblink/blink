# Optional: override the client-side beta signup endpoint. Defaults to the
# production Railway URL embedded in the page if unset.
PUBLIC_BETA_SIGNUP_URL=https://blink-production-7b5a.up.railway.app/v1/beta-signup

# Optional: hosted MP4 URL for the first-viewport demo video (e.g. an R2 URL).
# If unset, the page renders a "demo coming soon" placeholder in the same slot.
PUBLIC_DEMO_VIDEO_URL=https://downloads.useblink.dev/demo.mp4

# PostHog product analytics (browser-side). Without PUBLIC_POSTHOG_KEY set, the
# SDK no-ops at runtime so dev builds stay clean.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
