GEMINI_API_KEY=
BLINK_BOOTSTRAP_TOKEN=
BLINK_API_TOKENS=
BLINK_LEGACY_TOKEN_ALLOWED=true
DATABASE_URL=
REDIS_URL=
TLDR_ALLOWED_MODELS=gemini-3.1-flash-lite-preview
TLDR_EVENT_LOGGING=true
TLDR_CACHE_RESPONSES=true
TLDR_RESPONSE_CACHE_TTL_SECONDS=86400
TLDR_MINT_RATE_LIMIT_PER_MINUTE=5
# Set to true when running behind a trusted reverse proxy (Railway,
# Cloudflare, etc.) so /v1/auth/mint rate limiting reads the first
# X-Forwarded-For hop instead of the proxy IP.
TLDR_TRUST_PROXY_HEADERS=false
