GEMINI_API_KEY=
BLINK_BOOTSTRAP_TOKEN=
BLINK_API_TOKENS=
BLINK_LEGACY_TOKEN_ALLOWED=true
DATABASE_URL=
REDIS_URL=
BLINK_ALLOWED_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-3.1-pro-preview
BLINK_EVENT_LOGGING=true
BLINK_CACHE_RESPONSES=true
BLINK_RESPONSE_CACHE_TTL_SECONDS=86400
BLINK_THREAD_CACHE_TTL_SECONDS=600
BLINK_MINT_RATE_LIMIT_PER_MINUTE=5
BLINK_IP_HASH_SALT=
BLINK_SIGNUP_RATE_LIMIT_PER_MINUTE=5
BLINK_SIGNUP_RATE_LIMIT_PER_DAY=50
# Optional: Discord webhook URL that receives a notification on each new
# beta signup (duplicates are silent). Leave empty to disable.
BLINK_DISCORD_SIGNUP_WEBHOOK_URL=
# Set to true when running behind a trusted reverse proxy (Cloud Run,
# Cloudflare, etc.) so rate limiting reads the last X-Forwarded-For hop
# (the one appended by the proxy) instead of the proxy IP.
BLINK_TRUST_PROXY_HEADERS=false
# PostHog product analytics (server-side). Leave empty to disable.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
