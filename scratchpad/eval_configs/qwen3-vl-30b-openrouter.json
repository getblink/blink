{
  "name": "qwen3-vl-30b-openrouter",
  "provider": "openai_sdk",
  "model": "qwen/qwen3-vl-30b-a3b-instruct",
  "temperature": 0,
  "max_output_tokens": 512,
  "provider_options": {
    "api_style": "chat_completions",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "default_headers": {
      "HTTP-Referer": "https://github.com/henryz2004/blink",
      "X-Title": "Blink sweep"
    }
  }
}
