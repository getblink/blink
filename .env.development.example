# Dev-mode override for the Astro landing page.
#
# Loaded by `npm run dev` (mode=development) via Vite's env loader.
# `astro build` (mode=production) does not load this file, so Cloudflare
# Pages builds are unaffected. site/astro.config.mjs sets envDir to the
# repo root, which is why this lives here and not in site/.
#
# Copy to .env.development at the repo root and fill in if you want
# `npm run dev` to point at the staging backend. .env.development is
# gitignored. Conductor's setup.sh + sync_env.sh propagate the central
# copy at $CONDUCTOR_ROOT_PATH/.env.development into each workspace.

PUBLIC_BETA_SIGNUP_URL=https://api-staging.useblink.dev/v1/beta-signup
